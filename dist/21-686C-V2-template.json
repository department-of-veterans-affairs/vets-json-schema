              "fieldType": "string",
              "fieldValue": "{{ssn}}"
            },
            {
              "fieldLabel": "Dependent's date of birth:",
              "fieldFormat": "biographicalDate",
              "fieldType": "string",
              "fieldValue": "{{birthDate}}"
            },
            {
              "fieldLabel": "Date of death",
              "fieldFormat": "biographicalDate",
              "fieldType": "string",
              "fieldValue": "{{dependentDeathDate}}"
            },
            {
              "fieldLabel": "What was your relationship to this dependent?",
              "fieldOptions": [
                {
                  "label": "Spouse",
                  "value": "{{SPOUSE}}"
                },
                {
                  "label": "Dependent parent",
                  "value": "{{DEPENDENT_PARENT}}"
                },
                {
                  "label": "Child",
                  "value": "{{CHILD}}"
                }
              ]
            }
          ],
          "blocks": [
            {
              "blockLabel": "Where did this dependent die?",
              "fields": [
                {
                  "fieldLabel": "This occurred outside the U.S.",
                  "fieldValue": "{{formatBool dependentDeathLocation.outsideUsa '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "City:",
                  "fieldType": "string",
                  "fieldValue": "{{dependentDeathLocation.location.city}}"
                },
                {
                  "fieldLabel": "State:",
                  "fieldType": "string",
                  "fieldValue": "{{dependentDeathLocation.location.state}}",
                  "showUnless": "dependentDeathLocation.outsideUsa"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldType": "string",
                  "fieldValue": "{{dependentDeathLocation.location.country}}",
                  "showIf": "dependentDeathLocation.outsideUsa"
                }
              ]
            }
          ]
        }
      ]
