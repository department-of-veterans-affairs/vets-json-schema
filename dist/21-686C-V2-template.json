{
  "$schema": "https://vefs-forms-api.prod.bip.vba.va.gov/api/v1/rest/forms/formTemplateSchema/versions/1.0/schema",
  "formId": "21-686c",
  "formDescription": "Add or remove a dependent on VA benefits",
  "formVersion": "OMB Version Aug 2024, Release 1.3.4",
  "title": "21-686c Form Template",
  "description": "Form Template for 21-686c Application Request to Add and/or Remove Dependents",
  "version": "1.0",
  "sections": [
    {
      "sectionNumber": "1",
      "sectionId": "veteranInformationSection",
      "sectionHeader": "Section 1: Veteran information",
      "repeatable": false,
      "blocks": [
        {
          "blockLabel": "Personal information",
          "fields": [
            {
              "fieldLabel": "Name:",
              "fieldType": "string",
              "fieldValue": "{{veteranInformation.fullName.first}} {{#veteranInformation.fullName.middle}}{{.}} {{/veteranInformation.fullName.middle}}{{veteranInformation.fullName.last}}"
            },
            {
              "fieldLabel": "Social Security number:",
              "fieldFormat": "ssn",
              "fieldType": "string",
              "fieldValue": "{{veteranInformation.ssn}}"
            },
            {
              "fieldLabel": "Date of Birth:",
              "fieldFormat": "biographicalDate",
              "fieldType": "string",
              "fieldValue": "{{veteranInformation.birthDate}}"
            }
          ]
        },
        {
          "blockLabel": "Mailing address",
          "fields": [
            {
              "fieldLabel": "Country:",
              "fieldValue": "{{veteranContactInformation.veteranAddress.country}}"
            },
            {
              "fieldLabel": "Street address:",
              "fieldValue": "{{veteranContactInformation.veteranAddress.street}}"
            },
            {
              "fieldLabel": "Apartment or unit number:",
              "fieldValue": "{{veteranContactInformation.veteranAddress.street2}}"
            },
            {
              "showIf": "veteranContactInformation.veteranAddress.isMilitary",
              "fieldLabel": "Military post office:",
              "fieldFormat": "militaryPostOffice",
              "fieldValue": "{{veteranContactInformation.veteranAddress.city}}"
            },
            {
              "showUnless": "veteranContactInformation.veteranAddress.isMilitary",
              "fieldLabel": "City:",
              "fieldValue": "{{veteranContactInformation.veteranAddress.city}}"
            },
            {
              "showIf": "veteranContactInformation.veteranAddress.isMilitary",
              "fieldLabel": "Overseas 'state' abbreviation:",
              "fieldValue": "{{veteranContactInformation.veteranAddress.state}}"
            },
            {
              "showUnless": "veteranContactInformation.veteranAddress.isMilitary",
              "fieldLabel": "State:",
              "fieldValue": "{{veteranContactInformation.veteranAddress.state}}"
            },
            {
              "fieldLabel": "Postal code:",
              "fieldValue": "{{veteranContactInformation.veteranAddress.postalCode}}"
            }
          ]
        },
        {
          "blockLabel": "Phone and email address",
          "fields": [
            {
              "fieldLabel": "Phone number:",
              "fieldFormat": "phone",
              "fieldType": "string",
              "fieldValue": "{{veteranContactInformation.phoneNumber}}"
            },
            {
              "fieldLabel": "International phone number:",
              "fieldFormat": "internationalPhone",
              "fieldType": "string",
              "fieldValue": "{{veteranContactInformation.internationalPhoneNumber}}"
            },
            {
              "fieldLabel": "Email address:",
              "fieldType": "string",
              "fieldValue": "{{veteranContactInformation.emailAddress}}"
            },
            {
              "fieldLabel": "I agree to receive electronic correspondence from the VA about my claim.",
              "fieldValue": "{{formatBool veteranContactInformation.electronicCorrespondence '✓ Selected' 'Not selected'}}"
            }
          ]
        }
      ]
    },
    {
      "sectionNumber": "2",
      "sectionId": "spouseInformationSection",
      "sectionHeader": "Section 2: Add your spouse",
      "repeatable": false,
      "blocks": [
        {
          "blockLabel": "Your spouse's personal information",
          "fields": [
            {
              "fieldLabel": "Spouse's first name:",
              "fieldType": "string",
              "fieldValue": "{{spouseInformation.fullName.first}}"
            },
            {
              "fieldLabel": "Spouse's middle name:",
              "fieldType": "string",
              "fieldValue": "{{spouseInformation.fullName.middle}}"
            },
            {
              "fieldLabel": "Spouse's last name:",
              "fieldType": "string",
              "fieldValue": "{{spouseInformation.fullName.last}}"
            },
            {
              "fieldLabel": "Spouse's date of birth:",
              "fieldFormat": "biographicalDate",
              "fieldType": "date",
              "fieldValue": "{{spouseInformation.birthDate}}"
            },
            {
              "fieldLabel": "Spouse's Social Security number:",
              "fieldFormat": "ssn",
              "fieldType": "string",
              "fieldValue": "{{spouseInformation.ssn}}"
            },
            {
              "fieldLabel": "Is your spouse a Veteran?",
              "fieldValue": "{{formatBool spouseInformation.isVeteran 'Yes' 'No'}}"
            },
            {
              "showIf": "spouseInformation.isVeteran",
              "fieldLabel": "Spouse's VA file number:",
              "fieldType": "string",
              "fieldValue": "{{spouseInformation.vaFileNumber}}"
            },
            {
              "showIf": "spouseInformation.isVeteran",
              "fieldLabel": "Spouse's military service number:",
              "fieldType": "string",
              "fieldValue": "{{spouseInformation.serviceNumber}}"
            }
          ]
        },
        {
          "blockLabel": "Information about your marriage",
          "fields": [
            {
              "fieldLabel": "Do you live with your spouse?",
              "fieldValue": "{{formatBool doesLiveWithSpouse.spouseDoesLiveWithVeteran 'Yes' 'No'}}"
            },
            {
              "fieldLabel": "When did you get married?",
              "fieldType": "date",
              "fieldFormat": "biographicalDate",
              "fieldValue": "{{currentMarriageInformation.date}}"
            }
          ]
        },
        {
          "blockLabel": "Where did you get married?",
          "fields": [
            {
              "fieldLabel": "This occurred outside the U.S.",
              "fieldValue": "{{formatBool currentMarriageInformation.outsideUsa '✓ Selected' 'Not selected'}}"
            },
            {
              "fieldLabel": "City:",
              "fieldType": "string",
              "fieldValue": "{{currentMarriageInformation.location.city}}"
            },
            {
              "fieldLabel": "State:",
              "fieldType": "string",
              "fieldValue": "{{currentMarriageInformation.location.state}}",
              "showUnless": "currentMarriageInformation.outsideUsa"
            },
            {
              "fieldLabel": "Country:",
              "fieldType": "string",
              "fieldValue": "{{currentMarriageInformation.location.country}}",
              "showIf": "currentMarriageInformation.outsideUsa"
            }
          ]
        },
        {
          "blockLabel": "How did you get married?",
          "fields": [
            {
              "fieldId": "marriageType",
              "fieldLabel": "How did you get married?",
              "fieldType": "string",
              "fieldValue": "{{currentMarriageInformation.typeOfMarriage}}",
              "fieldDisplayMap": {
                "CIVIL": "In a civil ceremony with an officiant who signed my marriage license",
                "CEREMONIAL": "In a religious ceremony with a clergyperson who signed my marriage license",
                "COMMON-LAW": "By common law",
                "PROXY": "By proxy",
                "TRIBAL": "In a tribal ceremony",
                "OTHER": "Some other way: {{currentMarriageInformation.typeOther}}"
              }
            }
          ]
        },
        {
          "blockLabel": "Spouse's address",
          "showUnless": "doesLiveWithSpouse.spouseDoesLiveWithVeteran",
          "fields": [
            {
              "fieldLabel": "Country:",
              "fieldValue": "{{doesLiveWithSpouse.address.country}}"
            },
            {
              "fieldLabel": "Street address:",
              "fieldValue": "{{doesLiveWithSpouse.address.street}}"
            },
            {
              "fieldLabel": "Apartment or unit number:",
              "fieldValue": "{{doesLiveWithSpouse.address.street2}}"
            },
            {
              "showIf": "doesLiveWithSpouse.address.isMilitary",
              "fieldLabel": "Military post office:",
              "fieldFormat": "militaryPostOffice",
              "fieldValue": "{{doesLiveWithSpouse.address.city}}"
            },
            {
              "showUnless": "doesLiveWithSpouse.address.isMilitary",
              "fieldLabel": "City:",
              "fieldValue": "{{doesLiveWithSpouse.address.city}}"
            },
            {
              "showIf": "doesLiveWithSpouse.address.isMilitary",
              "fieldLabel": "Overseas 'state' abbreviation:",
              "fieldValue": "{{address.state}}"
            },
            {
              "showUnless": "doesLiveWithSpouse.address.isMilitary",
              "fieldLabel": "State:",
              "fieldValue": "{{doesLiveWithSpouse.address.state}}"
            },
            {
              "fieldLabel": "Postal code:",
              "fieldValue": "{{doesLiveWithSpouse.address.postalCode}}"
            }
          ]
        },
        {
          "repeatable": "spouseMarriageHistory",
          "blockLabel": "Spouse's former spouse: {{fullName.first}} {{fullName.middle}} {{fullName.last}}",
          "fields": [
            {
              "fieldLabel": "First name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.first}}"
            },
            {
              "fieldLabel": "Middle name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.middle}}"
            },
            {
              "fieldLabel": "Last name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.last}}"
            },
            {
              "fieldLabel": "How did your spouse's previous marriage end?",
              "fieldType": "string",
              "fieldValue": "{{reasonMarriageEnded}}",
              "fieldDisplayMap": {
                "Death": "Their former spouse died",
                "Divorce": "They divorced",
                "Annulment": "They got an annulment",
                "Other": "Some other way: {{otherReasonMarriageEnded}}"
              }
            },
            {
              "fieldLabel": "When did your spouse's previous get married?",
              "fieldType": "string",
              "fieldFormat": "biographicalDate",
              "fieldValue": "{{startDate}}"
            },
            {
              "fieldLabel": "When did your spouse's previous marriage end?",
              "fieldType": "string",
              "fieldFormat": "biographicalDate",
              "fieldValue": "{{endDate}}"
            }
          ],
          "blocks": [
            {
              "blockLabel": "Where did your spouse previously get married?",
              "fields": [
                {
                  "fieldLabel": "This occurred outside the U.S.",
                  "fieldValue": "{{formatBool startLocation.outsideUsa '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "City:",
                  "fieldType": "string",
                  "fieldValue": "{{startLocation.location.city}}"
                },
                {
                  "fieldLabel": "State:",
                  "fieldType": "string",
                  "fieldValue": "{{startLocation.location.state}}",
                  "showUnless": "startLocation.outsideUsa"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldType": "string",
                  "fieldValue": "{{startLocation.location.country}}",
                  "showIf": "startLocation.outsideUsa"
                }
              ]
            },
            {
              "blockLabel": "Where did the marriage end?",
              "fields": [
                {
                  "fieldLabel": "This occurred outside the U.S.",
                  "fieldValue": "{{formatBool endLocation.outsideUsa '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "City:",
                  "fieldType": "string",
                  "fieldValue": "{{endLocation.location.city}}"
                },
                {
                  "fieldLabel": "State:",
                  "fieldType": "string",
                  "fieldValue": "{{endLocation.location.state}}",
                  "showUnless": "endLocation.outsideUsa"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldType": "string",
                  "fieldValue": "{{endLocation.location.country}}",
                  "showIf": "endLocation.outsideUsa"
                }
              ]
            }
          ]
        },
        {
          "repeatable": "veteranMarriageHistory",
          "blockLabel": "Your former marriage: {{fullName.first}} {{fullName.middle}} {{fullName.last}}",
          "fields": [
            {
              "fieldLabel": "First name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.first}}"
            },
            {
              "fieldLabel": "Middle name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.middle}}"
            },
            {
              "fieldLabel": "Last name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.last}}"
            },
            {
              "fieldLabel": "How did your marriage end?",
              "fieldType": "string",
              "fieldValue": "{{reasonMarriageEnded}}",
              "fieldDisplayMap": {
                "Death": "My former spouse died",
                "Divorce": "We divorced",
                "Annulment": "We got an annulment",
                "Other": "Some other way: {{otherReasonMarriageEnded}}"
              }
            },
            {
              "fieldLabel": "When did you get married?",
              "fieldType": "string",
              "fieldFormat": "biographicalDate",
              "fieldValue": "{{startDate}}"
            },
            {
              "fieldLabel": "When did your marriage end?",
              "fieldType": "string",
              "fieldFormat": "biographicalDate",
              "fieldValue": "{{endDate}}"
            }
          ],
          "blocks": [
            {
              "blockLabel": "Where did you get married:",
              "fields": [
                {
                  "fieldLabel": "This occurred outside the U.S.",
                  "fieldValue": "{{formatBool startLocation.outsideUsa '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "City:",
                  "fieldType": "string",
                  "fieldValue": "{{startLocation.location.city}}"
                },
                {
                  "fieldLabel": "State:",
                  "fieldType": "string",
                  "fieldValue": "{{startLocation.location.state}}",
                  "showUnless": "startLocation.outsideUsa"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldType": "string",
                  "fieldValue": "{{startLocation.location.country}}",
                  "showIf": "startLocation.outsideUsa"
                }
              ]
            },
            {
              "blockLabel": "Where did the marriage end?",
              "fields": [
                {
                  "fieldLabel": "This occurred outside the U.S.",
                  "fieldValue": "{{formatBool endLocation.outsideUsa '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "City:",
                  "fieldType": "string",
                  "fieldValue": "{{endLocation.location.city}}"
                },
                {
                  "fieldLabel": "State:",
                  "fieldType": "string",
                  "fieldValue": "{{endLocation.location.state}}",
                  "showUnless": "endLocation.outsideUsa"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldType": "string",
                  "fieldValue": "{{startLocation.location.country}}",
                  "showIf": "endLocation.outsideUsa"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "sectionNumber": "3",
      "sectionId": "addChildrenSection",
      "sectionHeader": "Section 3: Add one or more children",
      "blocks": [
        {
          "repeatable": "childrenToAdd",
          "blockLabel": "Child {{LIST_INDEX}}: {{fullName.first}} {{fullName.middle}} {{fullName.last}}",
          "fields": [
            {
              "fieldLabel": "Child's first name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.first}}"
            },
            {
              "fieldLabel": "Child's middle name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.middle}}"
            },
            {
              "fieldLabel": "Child's last name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.last}}"
            },
            {
              "fieldLabel": "Child's date of birth:",
              "fieldFormat": "biographicalDate",
              "fieldType": "date",
              "fieldValue": "{{birthDate}}"
            },
            {
              "fieldLabel": "Child's Social Security number:",
              "fieldFormat": "ssn",
              "fieldType": "string",
              "fieldValue": "{{ssn}}"
            },
            {
              "blockLabel": "Child birth place?",
              "fields": [
                {
                  "fieldLabel": "This child was born outside the U.S.",
                  "fieldValue": "{{formatBool birthLocation.outsideUsa '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "City:",
                  "fieldType": "string",
                  "fieldValue": "{{birthLocation.location.city}}"
                },
                {
                  "fieldLabel": "State:",
                  "fieldType": "string",
                  "fieldValue": "{{birthLocation.location.state}}",
                  "showUnless": "birthLocation.outsideUsa"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldType": "string",
                  "fieldValue": "{{birthLocation.location.country}}",
                  "showIf": "birthLocation.outsideUsa"
                },
                {
                  "fieldLabel": "Postal Code:",
                  "fieldFormat": "postalCode",
                  "fieldType": "string",
                  "fieldValue": "{{birthLocation.location.postalCode}}"
                }
              ]
            },
            {
              "blockLabel": "Your relationship to this child",
              "fields": [
                {
                  "fieldLabel": "Is this child your biological child?",
                  "fieldValue": "{{formatBool isBiologicalChild 'Yes' 'No'}}"
                },
                {
                  "showUnless": "isBiologicalChild",
                  "fieldLabel": "What's your relationship to this child?",
                  "fieldValue": "{{{getRelationshipDisplay relationshipToChild}}}"
                }
              ]
            },
            {
              "blockLabel": "Child's biological parents",
              "fields": [
                {
                  "fieldLabel": "Is this child the biological child of your current spouse?",
                  "fieldValue": "{{formatBool isBiologicalChildOfSpouse 'Yes' 'No'}}"
                },
                {
                  "fieldLabel": "Date this child entered your household:",
                  "fieldFormat": "biographicalDate",
                  "fieldType": "date",
                  "fieldValue": "{{dateEnteredHousehold}}"
                },
                {
                  "fieldLabel": "Child's biological parent's first name:",
                  "fieldType": "string",
                  "fieldValue": "{{biologicalParentName.first}}"
                },
                {
                  "fieldLabel": "Child's biological parent's last name:",
                  "fieldType": "string",
                  "fieldValue": "{{biologicalParentName.last}}"
                },
                {
                  "fieldLabel": "Child's biological parent's Social Security number:",
                  "fieldFormat": "ssn",
                  "fieldType": "string",
                  "fieldValue": "{{biologicalParentSsn}}"
                },
                {
                  "fieldLabel": "Child's biological parent's date of birth:",
                  "fieldFormat": "biographicalDate",
                  "fieldType": "date",
                  "fieldValue": "{{biologicalParentDob}}"
                }
              ]
            },
            {
              "blockLabel": "Child's disability status",
              "fields": [
                {
                  "fieldLabel": "Does this child have a permanent mental or physical disability?",
                  "fieldValue": "{{formatBool doesChildHaveDisability 'Yes' 'No'}}"
                }
              ]
            },
            {
              "blockLabel": "Child's disability details",
              "fields": [
                {
                  "fieldLabel": "Is this child permanently unable to support themselves because they developed a permanent mental or physical disability before they turned 18 years old?",
                  "fieldValue": "{{formatBool doesChildHavePermanentDisability 'Yes' 'No'}}"
                }
              ]
            },
            {
              "blockLabel": "Additional information about this child",
              "fields": [
                {
                  "fieldLabel": "Does this child live with you?",
                  "fieldValue": "{{formatBool doesChildLiveWithYou 'Yes' 'No'}}"
                },
                {
                  "fieldLabel": "Has this child ever been married?",
                  "fieldValue": "{{formatBool hasChildEverBeenMarried 'Yes' 'No'}}"
                },
                {
                  "showIf": "hasChildEverBeenMarried",
                  "fieldLabel": "When did this marriage end?",
                  "fieldFormat": "biographicalDate",
                  "fieldType": "string",
                  "fieldValue": "{{marriageEndDate}}"
                },
                {
                  "showIf": "hasChildEverBeenMarried",
                  "fieldLabel": "How did the marriage end?",
                  "fieldType": "string",
                  "fieldValue": "{{marriageEndReason}}",
                  "fieldDisplayMap": {
                    "Death": "Their former spouse died",
                    "Divorce": "They divorced",
                    "Annulment": "They got an annulment",
                    "Other": "Some other way: {{marriageEndDescription}}"
                  }
                }
              ]
            },
            {
              "blockLabel": "Child's address",
              "showIf": "address",
              "fields": [
                {
                  "fieldLabel": "This child lives on a United States military base outside of the U.S.",
                  "fieldValue": "{{formatBool address.isMilitary '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldValue": "{{address.country}}"
                },
                {
                  "fieldLabel": "Street address:",
                  "fieldValue": "{{address.street}}"
                },
                {
                  "fieldLabel": "Apartment or unit number:",
                  "fieldValue": "{{address.street2}}"
                },
                {
                  "showIf": "address.isMilitary",
                  "fieldLabel": "Military post office:",
                  "fieldFormat": "militaryPostOffice",
                  "fieldValue": "{{address.city}}"
                },
                {
                  "showUnless": "address.isMilitary",
                  "fieldLabel": "City:",
                  "fieldValue": "{{address.city}}"
                },
                {
                  "showIf": "address.isMilitary",
                  "fieldLabel": "Overseas 'state' abbreviation:",
                  "fieldValue": "{{address.state}}"
                },
                {
                  "showUnless": "address.isMilitary",
                  "fieldLabel": "State:",
                  "fieldValue": "{{address.state}}"
                },
                {
                  "fieldLabel": "Postal code:",
                  "fieldValue": "{{address.postalCode}}"
                }
              ]
            },
            {
              "blockLabel": "Who does this child live with?",
              "showIf": "livingWith",
              "fields": [
                {
                  "fieldLabel": "First name:",
                  "fieldType": "string",
                  "fieldValue": "{{livingWith.first}}"
                },
                {
                  "fieldLabel": "Middle name:",
                  "fieldType": "string",
                  "fieldValue": "{{livingWith.fullName.middle}}"
                },
                {
                  "fieldLabel": "Last name:",
                  "fieldType": "string",
                  "fieldValue": "{{livingWith.fullName.last}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "sectionNumber": "4",
      "sectionId": "divorcedSpouseSection",
      "sectionHeader": "Section 4: Remove a divorced spouse",
      "repeatable": false,
      "showIf": "reportDivorce",
      "blocks": [
        {
          "blockLabel": "Divorced spouse's information",
          "fields": [
            {
              "fieldLabel": "Former spouse first name:",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.fullName.first}}"
            },
            {
              "fieldLabel": "Former spouse middle name:",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.fullName.middle}}"
            },
            {
              "fieldLabel": "Former spouse last name:",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.fullName.last}}"
            },
            {
              "fieldLabel": "Former spouse date of birth:",
              "fieldFormat": "biographicalDate",
              "fieldType": "date",
              "fieldValue": "{{reportDivorce.birthDate}}"
            }
          ]
        },
        {
          "blockLabel": "When, where, and why did this marriage end?",
          "fields": [
            {
              "fieldLabel": "Date of divorce:",
              "fieldFormat": "biographicalDate",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.date}}"
            },
            {
              "fieldLabel": "This occurred outside the U.S.",
              "fieldValue": "{{formatBool reportDivorce.divorceLocation.outsideUsa '✓ Selected' 'Not selected'}}"
            },
            {
              "fieldLabel": "City:",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.divorceLocation.location.city}}"
            },
            {
              "fieldLabel": "State:",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.divorceLocation.location.state}}",
              "showUnless": "reportDivorce.divorceLocation.outsideUsa"
            },
            {
              "fieldLabel": "Country:",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.divorceLocation.location.country}}",
              "showIf": "reportDivorce.divorceLocation.outsideUsa"
            },
            {
              "fieldLabel": "How did your marriage end?",
              "fieldType": "string",
              "fieldValue": "{{reportDivorce.reasonMarriageEnded}}",
              "fieldDisplayMap": {
                "Divorce": "Divorce",
                "Other": "Annulment or other: {{reportDivorce.explanationOfOther}}"
              }
            }
          ]
        }
      ]
    },
    {
      "sectionNumber": "5",
      "sectionId": "stepchildrenSection",
      "sectionHeader": "Section 5: Remove one or more stepchildren who have left your household",
      "blocks": [
        {
          "repeatable": "stepChildren",
          "blockLabel": "Stepchild {{LIST_INDEX}}: {{fullName.first}} {{fullName.middle}} {{fullName.last}}",
          "fields": [
            {
              "fieldLabel": "Child's first name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.first}}"
            },
            {
              "fieldLabel": "Child's middle name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.middle}}"
            },
            {
              "fieldLabel": "Child's last name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.last}}"
            },
            {
              "fieldLabel": "Child's Social Security number:",
              "fieldFormat": "ssn",
              "fieldType": "string",
              "fieldValue": "{{ssn}}"
            },
            {
              "fieldLabel": "Child's date of birth:",
              "fieldFormat": "biographicalDate",
              "fieldType": "string",
              "fieldValue": "{{birthDate}}"
            },
            {
              "fieldLabel": "When did your stepchild leave your household?",
              "fieldFormat": "biographicalDate",
              "fieldType": "date",
              "fieldValue": "{{dateStepchildLeftHousehold}}"
            },
            {
              "fieldLabel": "Are you still supporting this stepchild?",
              "fieldValue": "{{formatBool supportingStepchild 'Yes' 'No'}}"
            },
            {
              "fieldLabel": "Do you provide at least half of your stepchild’s financial support?",
              "fieldType": "string",
              "fieldValue": "{{livingExpensesPaid}}",
              "fieldDisplayMap": {
                "More than half": "Yes",
                "Less than half": "No"
              }
            }
          ],
          "blocks": [
            {
              "blockLabel": "Stepchild's address",
              "showIf": "address",
              "fields": [
                {
                  "fieldLabel": "This child lives on a United States military base outside of the U.S.",
                  "fieldValue": "{{formatBool address.isMilitary '✓ Selected' 'Not selected'}}"
                },
                {
                  "fieldLabel": "Country:",
                  "fieldValue": "{{address.country}}"
                },
                {
                  "fieldLabel": "Street address:",
                  "fieldValue": "{{address.street}}"
                },
                {
                  "fieldLabel": "Apartment or unit number:",
                  "fieldValue": "{{address.street2}}"
                },
                {
                  "showIf": "address.isMilitary",
                  "fieldLabel": "Military post office:",
                  "fieldFormat": "militaryPostOffice",
                  "fieldValue": "{{address.city}}"
                },
                {
                  "showUnless": "address.isMilitary",
                  "fieldLabel": "City:",
                  "fieldValue": "{{address.city}}"
                },
                {
                  "showIf": "address.isMilitary",
                  "fieldLabel": "Overseas 'state' abbreviation:",
                  "fieldValue": "{{address.state}}"
                },
                {
                  "showUnless": "address.isMilitary",
                  "fieldLabel": "State:",
                  "fieldValue": "{{address.state}}"
                },
                {
                  "fieldLabel": "Postal code:",
                  "fieldValue": "{{address.postalCode}}"
                }
              ]
            },
            {
              "blockLabel": "Who does this stepchild live with?",
              "fields": [
                {
                  "fieldLabel": "Parent or guardian's first name:",
                  "fieldType": "string",
                  "fieldValue": "{{whoDoesTheStepchildLiveWith.first}}"
                },
                {
                  "fieldLabel": "Parent or guardian's middle name:",
                  "fieldType": "string",
                  "fieldValue": "{{whoDoesTheStepchildLiveWith.middle}}"
                },
                {
                  "fieldLabel": "Parent or guardian's  last name:",
                  "fieldType": "string",
                  "fieldValue": "{{whoDoesTheStepchildLiveWith.last}}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "sectionNumber": "6",
      "sectionId": "deceasedDependentsSection",
      "sectionHeader": "Section 6: Remove one or more dependents who have died",
      "blocks": [
        {
          "repeatable": "deaths",
          "blockLabel": "Deceased dependent {{LIST_INDEX}}: {{fullName.first}} {{fullName.middle}} {{fullName.last}}",
          "fields": [
            {
              "fieldLabel": "First name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.first}}"
            },
            {
              "fieldLabel": "Middle name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.middle}}"
            },
            {
              "fieldLabel": "Last name:",
              "fieldType": "string",
              "fieldValue": "{{fullName.last}}"
            },
            {
              "fieldLabel": "Dependent's Social Security number:",
