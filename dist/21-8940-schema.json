{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "APPLICATION FOR INCREASED COMPENSATION BASED ON UNEMPLOYABILITY (21-8940)",
  "type": "object",
  "properties": {
    "veteranFullName": {
      "type": "object",
      "first": {
        "type": "string",
        "maxLength": 12
      },
      "middleinitial": {
        "type": "string",
        "maxLength": 1
      },
      "last": {
        "type": "string",
        "maxLength": 18
      }
    },
    "veteranSocialSecurityNumber": {
      "type": "string",
      "pattern": "^[0-9]{9}$"
    },
    "vaFileNumber": {
      "type": "string",
      "pattern": "^[cC]{0,1}\\d{7,9}$"
    },
    "dateOfBirth": {
      "pattern": "^(\\d{4}|XXXX)-(0[1-9]|1[0-2]|XX)-(0[1-9]|[1-2][0-9]|3[0-1]|XX)$",
      "type": "string"
    },
    "veteranAddress": {
      "$ref": "#/definitions/usAddress",
      "country": {
        "type": "string",
        "maxLength": 2
      }
    },
    "electronicCorrespondance": {
      "type": "boolean"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "veteranPhone": {
      "type": "string",
      "pattern": "^\\d{10}$"
    },
    "internationalPhone": {
      "type": "string"
    },
    "listOfDisabilities": {
      "maxLength": 81,
      "type": "string"
    },
    "doctorsCareInLastYTD": {
      "type": "boolean"
    },
    "doctorsTreatmentDates": {
      "type": "object",
      "properties": {
        "from": {
          "$ref": "#/definitions/date"
        },
        "to": {
          "$ref": "#/definitions/date"
        }
      }
    },
    "nameAndAddressesOfDoctors": {
      "maxLength": 135,
      "type": "string"
    },
    "nameAndAddressesOfHospitals": {
      "maxLength": 127,
      "type": "string"
    },
    "hospitalCareDateRanges": {
      "type": "object",
      "properties": {
        "from": {
          "$ref": "#/definitions/date"
        },
        "to": {
          "$ref": "#/definitions/date"
        }
      }
    },
    "disabilityAffectEmployFTDate": {
      "pattern": "^(\\d{4}|XXXX)-(0[1-9]|1[0-2]|XX)-(0[1-9]|[1-2][0-9]|3[0-1]|XX)$",
      "type": "string"
    },
    "lastWorkedFullTimeDate": {
      "pattern": "^(\\d{4}|XXXX)-(0[1-9]|1[0-2]|XX)-(0[1-9]|[1-2][0-9]|3[0-1]|XX)$",
      "type": "string"
    },
    "becameTooDisabledToWorkDate": {
      "pattern": "^(\\d{4}|XXXX)-(0[1-9]|1[0-2]|XX)-(0[1-9]|[1-2][0-9]|3[0-1]|XX)$",
      "type": "string"
    },
    "mostEarningsInAYear": {
      "type": "integer"
    },
    "yearOfMostEarnings": {
      "maxLength": 4,
      "type": "integer"
    },
    "occupationDuringMostEarnings": {
      "type": "string",
      "maxLength": 27
    },
    "previousEmployers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nameAndAddress": {
            "maxLength": 110,
            "type": "string"
          },
          "typeOfWork": {
            "maxLength": 39,
            "type": "string"
          },
          "hoursPerWeek": {
            "type": "integer"
          },
          "datesOfEmployment": {
            "type": "object",
            "properties": {
              "from": {
                "$ref": "#/definitions/date"
              },
              "to": {
                "$ref": "#/definitions/date"
              }
            }
          },
          "timeLostFromIllness": {
            "type": "integer"
          },
          "mostEarningsInAMonth": {
            "type": "integer"
          }
        }
      }
    },
    "preventMilitaryDuties": {
      "type": "boolean"
    },
    "past12MonthsEarnedIncome": {
      "type": "integer"
    },
    "currentMonthlyEarnedIncome": {
      "type": "integer"
    },
    "leftLastJobDueToDisability": {
      "type": "boolean"
    },
    "expectDisabilityRetirement": {
      "type": "boolean"
    },
    "receiveExpectWorkersCompensation": {
      "type": "boolean"
    },
    "attemptedEmploy": {
      "type": "boolean"
    },
    "appliedEmployers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nameAndAddress": {
            "maxLength": 110,
            "type": "string"
          },
          "typeOfWork": {
            "maxLength": 62,
            "type": "string"
          },
          "dateApplied": {
            "pattern": "^(\\d{4}|XXXX)-(0[1-9]|1[0-2]|XX)-(0[1-9]|[1-2][0-9]|3[0-1]|XX)$",
            "type": "string"
          }
        }
      }
    },
    "education": {
      "type": "object",
      "gradeSchool": {
        "enum": [
          1,
          2,
          3,
          4,
          5,
          6,
          7,
          8
        ]
      },
      "highSchool": {
        "enum": [
          9,
          10,
          11,
          12
        ]
      },
      "college": {
        "enum": [
          "Fresh",
          "Soph",
          "Jr",
          "Sr"
        ]
      }
    },
    "trainingPreDisabled": {
      "type": "boolean"
    },
    "educationTrainingPreUnemployability": {
      "type": "object",
      "name": {
        "maxLength": 12,
        "type": "string"
      },
      "dateOfTraining": {
        "type": "object",
        "properties": {
          "from": {
            "$ref": "#/definitions/date"
          },
          "to": {
            "$ref": "#/definitions/date"
          }
        }
      }
    },
    "trainingPostUnemployment": {
      "type": "boolean"
    },
    "educationTrainingPostUnemployability": {
      "type": "object",
      "name": {
        "maxLength": 12,
        "type": "string"
      },
      "datesOfTraining": {
        "type": "object",
        "properties": {
          "from": {
            "$ref": "#/definitions/date"
          },
          "to": {
            "$ref": "#/definitions/date"
          }
        }
      }
    },
    "remarks": {
      "type": "string",
      "maxLength": 603
    },
    "signature": {
      "type": "string"
    },
    "signatureDate": {
      "pattern": "^(\\d{4}|XXXX)-(0[1-9]|1[0-2]|XX)-(0[1-9]|[1-2][0-9]|3[0-1]|XX)$",
      "type": "string"
    },
    "witnessSignature1": {
      "type": "object",
      "signature": {
        "maxLength": 38,
        "type": "string"
      },
      "address": {
        "type": "string",
        "maxLength": 34
      }
    },
    "witnessSignature2": {
      "type": "object",
      "signature": {
        "maxLength": 38,
        "type": "string"
      },
      "address": {
        "type": "string",
        "maxLength": 34
      }
    }
  },
  "required": []
}
