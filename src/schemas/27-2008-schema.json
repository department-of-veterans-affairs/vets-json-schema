// src/schemas/27-2008-schema.json
{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "VA Form 27-2008 — Application for United States Flag for Burial Purposes",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "ssn": {
      "type": "string",
      "pattern": "^\\d{9}$"
    },
    "phone": {
      "type": "string",
      "pattern": "^\\d{10}$"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 254
    },
    "usaState": {
      "type": "string",
      "enum": [
        "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "DC", "FL",
        "GA", "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME",
        "MD", "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH",
        "NJ", "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI",
        "SC", "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI",
        "WY", "PR", "GU", "VI", "AS", "MP", "AA", "AE", "AP"
      ]
    },
    "address": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "street2": {
          "type": "string",
          "maxLength": 100
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "pattern": "^[A-Za-z\\s\\-]+$"
        },
        "state": {
          "$ref": "#/definitions/usaState"
        },
        "postalCode": {
          "type": "string",
          "pattern": "^\\d{5}(-\\d{4})?$"
        }
      },
      "required": ["street", "city", "state", "postalCode"]
    },
    "fullName": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        },
        "middleName": {
          "type": "string",
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']*$"
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        }
      },
      "required": ["firstName", "lastName"]
    },
    "claimantName": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        },
        "middleInitial": {
          "type": "string",
          "maxLength": 1,
          "pattern": "^[A-Za-z]?$"
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        }
      },
      "required": ["firstName", "lastName"]
    },
    "fileUpload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "confirmationCode": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["name", "size", "confirmationCode"]
    }
  },
  "properties": {
    "claimantType": {
      "type": "string",
      "enum": [
        "spouse",
        "child",
        "parent",
        "sibling",
        "otherNextOfKin",
        "closeFriend",
        "funeralDirector",
        "vsoRepresentative",
        "governmentOfficial",
        "authorizedRepresentative"
      ]
    },
    "claimant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        },
        "middleInitial": {
          "type": "string",
          "maxLength": 1,
          "pattern": "^[A-Za-z]?$"
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        },
        "email": {
          "$ref": "#/definitions/email"
        },
        "phone": {
          "$ref": "#/definitions/phone"
        },
        "address": {
          "$ref": "#/definitions/address"
        },
        "relationshipDescription": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500
        }
      },
      "required": ["firstName", "lastName", "email", "phone", "address"]
    },
    "veteran": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        },
        "middleName": {
          "type": "string",
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']*$"
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[A-Za-z\\s\\-']+$"
        },
        "ssn": {
          "$ref": "#/definitions/ssn"
        },
        "dateOfBirth": {
          "$ref": "#/definitions/date"
        },
        "dateOfDeath": {
          "$ref": "#/definitions/date"
        },
        "vaFileNumber": {
          "type": "string",
          "pattern": "^\\d{7,9}$"
        }
      },
      "required": ["firstName", "lastName", "ssn", "dateOfBirth", "dateOfDeath"]
    },
    "serviceInformation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "branchOfService": {
          "type": "string",
          "enum": [
            "army",
            "navy",
            "airForce",
            "marines",
            "coastGuard",
            "spaceForce",
            "publicHealthService",
            "noaa",
            "merchantMarine",
            "philippineArmy"
          ]
        },
        "serviceType": {
          "type": "string",
          "enum": ["activeDuty", "reserveGuard"]
        },
        "serviceEntryDate": {
          "$ref": "#/definitions/date"
        },
        "serviceSeparationDate": {
          "$ref": "#/definitions/date"
        },
        "rankAtDischarge": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "dischargeCharacter": {
          "type": "string",
          "enum": [
            "honorable",
            "generalUnderHonorableConditions",
            "otherThanHonorable",
            "badConduct",
            "dishonorable",
            "uncharacterized"
          ]
        },
        "warPeriods": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "wwi",
              "wwiI",
              "korea",
              "vietnam",
              "gulfWar",
              "postGulfWar",
              "operationEnduringFreedom",
              "operationIraqiFreedom",
              "operationNewDawn",
              "other"
            ]
          }
        }
      },
      "required": [
        "branchOfService",
        "serviceType",
        "serviceEntryDate",
        "serviceSeparationDate",
        "dischargeCharacter"
      ]
    },
    "reserveGuardEligibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entitledToRetiredPay": {
          "type": "boolean"
        },
        "diedWhileActiveMember": {
          "type": "boolean"
        },
        "hospitalizedAtVaForServiceConnectedCondition": {
          "type": "boolean"
        }
      },
      "required": [
        "entitledToRetiredPay",
        "diedWhileActiveMember",
        "hospitalizedAtVaForServiceConnectedCondition"
      ]
    },
    "specialServiceCategories": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "merchantMarinerWwiiQualifyingService": {
          "type": "boolean"
        },
        "commissionedOfficerPublicHealthService": {
          "type": "boolean"
        },
        "philippineCommonwealthArmyOrGuerrilla": {
          "type": "boolean"
        }
      },
      "required": [
        "merchantMarinerWwiiQualifyingService",
        "commissionedOfficerPublicHealthService",
        "philippineCommonwealthArmyOrGuerrilla"
      ]
    },
    "priorFlagInformation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "priorFlagIssued": {
          "type": "boolean"
        },
        "replacementReason": {
          "type": "string",
          "enum": [
            "destroyedInDisaster",
            "stolen",
            "neverReceived",
            "other"
          ]
        },
        "replacementReasonDescription": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      },
      "required": ["priorFlagIssued"]
    },
    "dischargeDocumentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hasDd214": {
          "type": "boolean"
        },
        "alternativeDocumentation": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "npcRequest",
              "militaryOrders",
              "buddyStatement",
              "vaRecords",
              "other"
            ]
          }
        },
        "uploads": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/fileUpload"
          },
          "maxItems": 10
        }
      },
      "required": ["hasDd214"]
    },
    "burialInformation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "burialType": {
          "type": "string",
          "enum": [
            "casketBurial",
            "cremationWithUrn",
            "other"
          ]
        },
        "burialAtNationalCemetery": {
          "type": "boolean"
        },
        "cemeteryOrBurialPlace": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "burialCity": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "pattern": "^[A-Za-z\\s\\-]+$"
        },
        "burialState": {
          "$ref": "#/definitions/usaState"
        },
        "burialServiceDate": {
          "$ref": "#/definitions/date"
        }
      },
      "required": [
        "burialType",
        "burialAtNationalCemetery",
        "cemeteryOrBurialPlace",
        "burialCity",
        "burialState",
        "burialServiceDate"
      ]
    },
    "flagDelivery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flagRecipientIsSameAsClaimant": {
          "type": "boolean"
        },
        "flagRecipient": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "firstName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 30,
              "pattern": "^[A-Za-z\\s\\-']+$"
            },
            "middleInitial": {
              "type": "string",
              "maxLength": 1,
              "pattern": "^[A-Za-z]?$"
            },
            "lastName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 30,
              "pattern": "^[A-Za-z\\s\\-']+$"
            },
            "address": {
              "$ref": "#/definitions/address"
            }
          },
          "required": ["firstName", "lastName"]
        },
        "deliveryMethod": {
          "type": "string",
          "enum": [
            "mailToAddress",
            "pickUpAtVaFacility"
          ]
        }
      },
      "required": ["flagRecipientIsSameAsClaimant"]
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "certifyInformationIsAccurate": {
          "type": "boolean",
          "enum": [true]
        },
        "understandFlagIssuancePolicy": {
          "type": "boolean",
          "enum": [true]
        },
        "signature": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        }
      },
      "required": [
        "certifyInformationIsAccurate",
        "understandFlagIssuancePolicy",
        "signature"
      ]
    }
  },
  "required": [
    "claimantType",
    "claimant",
    "veteran",
    "serviceInformation",
    "priorFlagInformation",
    "dischargeDocumentation",
    "burialInformation",
    "flagDelivery",
    "attestation"
  ]
}