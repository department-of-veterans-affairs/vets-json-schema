// src/schemas/22-1999-schema.json
{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "VA Form 22-1999 — Enrollment Certification",
  "description": "Schema for VA Form 22-1999 submitted by School Certifying Officials (SCOs) to certify student enrollment for GI Bill benefits.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scoVerification",
    "certificationTypeInfo",
    "studentInformation",
    "institutionInformation",
    "programInformation",
    "enrollmentPeriod",
    "creditHours",
    "certifyingOfficial"
  ],
  "definitions": {
    "address": {
      "type": "object",
      "additionalProperties": false,
      "required": ["street", "city", "state", "postalCode"],
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "street2": {
          "type": "string",
          "maxLength": 100
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "state": {
          "type": "string",
          "enum": [
            "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
            "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
            "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
            "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
            "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
            "DC", "PR", "GU", "VI", "AS", "MP"
          ]
        },
        "postalCode": {
          "type": "string",
          "pattern": "^\\d{5}(?:-\\d{4})?$"
        },
        "country": {
          "type": "string",
          "maxLength": 50
        }
      }
    },
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "usPhone": {
      "type": "string",
      "pattern": "^\\d{10}$",
      "minLength": 10,
      "maxLength": 10
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 256
    },
    "facilityCode": {
      "type": "string",
      "pattern": "^\\d{8}$",
      "minLength": 8,
      "maxLength": 8
    },
    "ssn": {
      "type": "string",
      "pattern": "^(?!000|666|9\\d{2})\\d{3}(?!00)\\d{2}(?!0000)\\d{4}$",
      "minLength": 9,
      "maxLength": 9
    },
    "vaFileNumber": {
      "type": "string",
      "pattern": "^\\d{7,9}$",
      "minLength": 7,
      "maxLength": 9
    },
    "dollarAmount": {
      "type": "number",
      "minimum": 0,
      "maximum": 999999.99
    },
    "creditHourCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 99
    }
  },
  "properties": {
    "scoVerification": {
      "type": "object",
      "title": "SCO and Institution Verification",
      "description": "Chapter 1 — Verifies that the submitter is a designated School Certifying Official for a VA-approved institution.",
      "additionalProperties": false,
      "required": ["scoName", "facilityCode"],
      "properties": {
        "scoName": {
          "type": "string",
          "title": "SCO full name",
          "description": "Full name of the School Certifying Official. Pre-filled from authenticated VA.gov profile. Must match the name on file with VA for the institution.",
          "minLength": 2,
          "maxLength": 100,
          "pattern": "^[A-Za-z\\s'\\-]+$"
        },
        "facilityCode": {
          "$ref": "#/definitions/facilityCode",
          "title": "VA facility code",
          "description": "The institution's 8-digit VA-assigned facility code. Must match an active record in VA Education Service's facility code registry."
        },
        "institutionVerified": {
          "type": "boolean",
          "title": "Institution verified by back-end lookup",
          "description": "Set to true when the facility code lookup returns a valid active institution record. Used as a guard before allowing form progression.",
          "default": false
        },
        "scoRole": {
          "type": "string",
          "title": "SCO role designation",
          "description": "The SCO's role as registered with VA Education Service.",
          "enum": [
            "primary_certifying_official",
            "alternate_certifying_official",
            "secondary_certifying_official"
          ]
        }
      }
    },
    "certificationTypeInfo": {
      "type": "object",
      "title": "Certification Type",
      "description": "Chapter 2 — Identifies whether this is an original, amended, or termination certification. Phase 1 supports original certifications only.",
      "additionalProperties": false,
      "required": ["certificationType"],
      "properties": {
        "certificationType": {
          "type": "string",
          "title": "Certification type",
          "description": "The type of enrollment certification being submitted.",
          "enum": [
            "original",
            "amended",
            "termination"
          ]
        }
      }
    },
    "studentInformation": {
      "type": "object",
      "title": "Student Identifying Information",
      "description": "Chapter 3 — Identifies the student whose enrollment is being certified.",
      "additionalProperties": false,
      "required": ["firstName", "lastName", "dateOfBirth", "giChapter"],
      "properties": {
        "firstName": {
          "type": "string",
          "title": "Student first name",
          "minLength": 1,
          "maxLength": 50,
          "pattern": "^[A-Za-z\\s'\\-]+$"
        },
        "middleName": {
          "type": "string",
          "title": "Student middle name",
          "description": "Optional. Student's middle name or initial.",
          "maxLength": 50,
          "pattern": "^[A-Za-z\\s'\\-]*$"
        },
        "lastName": {
          "type": "string",
          "title": "Student last name",
          "minLength": 1,
          "maxLength": 50,
          "pattern": "^[A-Za-z\\s'\\-]+$"
        },
        "ssn": {
          "$ref": "#/definitions/ssn",
          "title": "Student Social Security number",
          "description": "Required if VA file number is not provided. 9-digit SSN without dashes. Cannot begin with 000, 666, or 900-999. Cannot be all the same digit."
        },
        "vaFileNumber": {
          "$ref": "#/definitions/vaFileNumber",
          "title": "Student VA file number",
          "description": "Required if SSN is not provided. 7–9 digit VA file number found on the student's Certificate of Eligibility."
        },
        "dateOfBirth": {
          "$ref": "#/definitions/date",
          "title": "Student date of birth",
          "description": "Student's date of birth. Must represent a date between 1900-01-01 and (current date minus 16 years). Student must be at least 16 years old."
        },
        "giChapter": {
          "type": "string",
          "title": "GI Bill chapter",
          "description": "The GI Bill chapter under which the student is receiving benefits. Determines how VA calculates and pays education benefits.",
          "enum": [
            "33",
            "30",
            "1606",
            "35",
            "32"
          ]
        }
      }
    },
    "studentEligibility": {
      "type": "object",
      "title": "Student COE / Eligibility Check Result",
      "description": "Chapter 4 interstitial — Records the result of the Certificate of Eligibility lookup performed when the SCO navigates to the eligibility check screen. This is a read-only system-populated section.",
      "additionalProperties": false,
      "properties": {
        "coeFound": {
          "type": "boolean",
          "title": "Certificate of Eligibility found",
          "description": "True if the VA back-end COE lookup returned a valid active COE for the student."
        },
        "entitlementRemaining": {
          "type": "number",
          "title": "Entitlement months remaining",
          "description": "Months of entitlement remaining on the student's COE, if returned by the lookup. Expressed as a decimal (e.g., 36.0 = full entitlement).",
          "minimum": 0,
          "maximum": 48
        },
        "scoAcknowledgedNoCoE": {
          "type": "boolean",
          "title": "SCO acknowledged no COE found and chose to continue",
          "description": "Set to true when the SCO selects 'Continue despite warning' after a no-COE-found result.",
          "default": false
        },
        "eligibilityCheckTimestamp": {
          "type": "string",
          "format": "date-time",
          "title": "Eligibility check timestamp",
          "description": "ISO 8601 UTC timestamp when the COE lookup was performed."
        }
      }
    },
    "institutionInformation": {
      "type": "object",
      "title": "Institution Information",
      "description": "Chapter 5 — Confirms institution details for the certification. Most fields are auto-populated from the facility code lookup.",
      "additionalProperties": false,
      "required": ["facilityCode", "institutionName", "institutionType", "publicOrPrivate"],
      "properties": {
        "facilityCode": {
          "$ref": "#/definitions/facilityCode",
          "title": "VA facility code",
          "description": "Carried from SCO verification. Read-only on this screen."
        },
        "institutionName": {
          "type": "string",
          "title": "Institution name",
          "description": "Auto-populated from the facility code lookup. Read-only.",
          "minLength": 1,
          "maxLength": 200
        },
        "institutionAddress": {
          "$ref": "#/definitions/address",
          "title": "Institution address",
          "description": "Auto-populated from the facility code lookup. Read-only."
        },
        "institutionType": {
          "type": "string",
          "title": "Institution program type",
          "description": "Type of institution for VA program purposes. Phase 1 supports IHL (Institution of Higher Learning) only.",
          "enum": [
            "IHL",
            "NCD",
            "flight",
            "correspondence",
            "OJT"
          ]
        },
        "publicOrPrivate": {
          "type": "string",
          "title": "Public or private institution",
          "description": "Whether the institution is public (state-funded) or private. Drives tuition cap logic for Chapter 33.",
          "enum": [
            "public",
            "private"
          ]
        },
        "institutionState": {
          "type": "string",
          "title": "Institution state",
          "description": "The US state where the institution is located. Used for in-state vs. out-of-state tuition cap determination under Chapter 33.",
          "enum": [
            "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
            "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
            "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
            "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
            "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
            "DC", "PR", "GU", "VI", "AS", "MP"
          ]
        },
        "studentState": {
          "type": "string",
          "title": "Student state of residence",
          "description": "The student's state of legal residence, used for in-state vs. out-of-state tuition determination at public institutions under Chapter 33.",
          "enum": [
            "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
            "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
            "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
            "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
            "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
            "DC", "PR", "GU", "VI", "AS", "MP"
          ]
        }
      }
    },
    "programInformation": {
      "type": "object",
      "title": "Program of Education",
      "description": "Chapter 6 — Captures the student's program of study including degree level, CIP code, and SAA approval cross-reference.",
      "additionalProperties": false,
      "required": ["programName", "degreeLevel"],
      "properties": {
        "programName": {
          "type": "string",
          "title": "Program name",
          "description": "The formal name of the program of education as approved by the State Approving Agency (SAA).",
          "minLength": 1,
          "maxLength": 200
        },
        "degreeLevel": {
          "type": "string",
          "title": "Degree or certificate level",
          "description": "The level of the credential awarded upon program completion.",
          "enum": [
            "associate",
            "bachelors",
            "masters",
            "doctoral",
            "certificate",
            "other"
          ]
        },
        "cipCode": {
          "type": "string",
          "title": "CIP code",
          "description": "Optional. The 6-digit Classification of Instructional Programs (CIP) code for the student's program.",
          "pattern": "^\\d{2}\\.\\d{4}$",
          "minLength": 7,
          "maxLength": 7
        },
        "saaApprovalVerified": {
          "type": "boolean",
          "title": "Program found in SAA-approved list",
          "description": "Set to true when the SAA program approval lookup confirms this program is approved for VA benefits at this institution."
        }
      }
    },
    "enrollmentPeriod": {
      "type": "object",
      "title": "Training Period / Enrollment Period",
      "description": "Chapter 7 — Captures the certification's training period begin and end dates and term type. Critical for payment start/stop and advance certification validation.",
      "additionalProperties": false,
      "required": ["enrollmentBeginDate", "enrollmentEndDate", "termType"],
      "properties": {
        "enrollmentBeginDate": {
          "$ref": "#/definitions/date",
          "title": "Enrollment begin date",
          "description": "First day of the training period being certified. May not be more than 120 days in the future (advance certification limit). Cannot be before the student's date of birth."
        },
        "enrollmentEndDate": {
          "$ref": "#/definitions/date",
          "title": "Enrollment end date",
          "description": "Last day of the training period being certified. Must be after the enrollment begin date."
        },
        "termType": {
          "type": "string",
          "title": "Term type",
          "description": "The academic term structure for this enrollment period.",
          "enum": [
            "semester",
            "quarter",
            "non_standard_session",
            "clock_hour_program"
          ]
        },
        "isAdvanceCertification": {
          "type": "boolean",
          "title": "Is advance certification",
          "description": "System-set flag indicating the enrollment begin date is in the future (1–120 days). Payment will not generate until the term start date.",
          "default": false
        }
      }
    },
    "creditHours": {
      "type": "object",
      "title": "Credit / Clock Hours and Rate of Pursuit",
      "description": "Chapter 8 — Captures credit or clock hours enrolled and the institution's full-time standard. System calculates rate of pursuit.",
      "additionalProperties": false,
      "required": ["hoursEnrolled", "institutionFullTimeHours", "trainingTimeClassification"],
      "properties": {
        "hoursEnrolled": {
          "$ref": "#/definitions/creditHourCount",
          "title": "Credit or clock hours enrolled",
          "description": "Number of credit or clock hours the student is enrolled in for this certification period."
        },
        "institutionFullTimeHours": {
          "$ref": "#/definitions/creditHourCount",
          "title": "Institution full-time credit hour standard",
          "description": "The number of credit or clock hours the institution considers full-time enrollment (e.g., 12 for undergraduate semester programs).",
          "minimum": 1,
          "maximum": 99
        },
        "calculatedRateOfPursuit": {
          "type": "number",
          "title": "Calculated rate of pursuit",
          "description": "System-calculated: hoursEnrolled ÷ institutionFullTimeHours. Read-only computed field. Value between 0.0 and 1.0 (or greater than 1.0 if over full-time).",
          "minimum": 0
        },
        "trainingTimeClassification": {
          "type": "string",
          "title": "Training time classification",
          "description": "The training time category based on rate of pursuit. System-suggested but SCO may override with justification.",
          "enum": [
            "full_time",
            "three_quarter_time",
            "half_time",
            "less_than_half_time"
          ]
        },
        "classificationOverridden": {
          "type": "boolean",
          "title": "SCO overrode system-suggested training time classification",
          "description": "True if the SCO manually selected a training time classification that differs from the system calculation.",
          "default": false
        },
        "overrideJustification": {
          "type": "string",
          "title": "Override justification",
          "description": "Required when classificationOverridden is true. SCO must provide a written justification for overriding the system-calculated training time.",
          "minLength": 10,
          "maxLength": 500
        }
      }
    },
    "tuitionAndFees": {
      "type": "object",
      "title": "Tuition and Fees",
      "description": "Chapter 9 — Captures tuition charged, mandatory fees, and waiver amounts for Chapter 33 certifications. System applies and displays applicable tuition cap.",
      "additionalProperties": false,
      "required": ["tuitionCharged", "mandatoryFees"],
      "properties": {
        "tuitionCharged": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Tuition charged by institution",
          "description": "Gross tuition amount charged by the institution for this enrollment period, before any waivers or scholarships."
        },
        "mandatoryFees": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Mandatory fees",
          "description": "Total mandatory fees charged to the student for this enrollment period."
        },
        "hasWaivers": {
          "type": "boolean",
          "title": "Student has tuition waivers or scholarships",
          "description": "Whether the student receives any tuition waivers, scholarships, or other remissions that reduce net tuition.",
          "default": false
        },
        "waiverAmount": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Tuition waiver or scholarship amount",
          "description": "Total dollar value of waivers and scholarships applied. Shown conditionally when hasWaivers is true."
        },
        "netTuition": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Net tuition after waivers",
          "description": "System-calculated: tuitionCharged minus waiverAmount. Read-only computed field."
        },
        "applicableTuitionCap": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Applicable tuition cap",
          "description": "System-populated: the applicable VA tuition cap for this student (in-state rate for public institutions; national maximum for private institutions under Chapter 33)."
        },
        "tuitionExceedsCap": {
          "type": "boolean",
          "title": "Net tuition exceeds applicable cap",
          "description": "System-set flag: true when net tuition exceeds the applicable cap. Amount certified will be the cap amount, not the net tuition.",
          "default": false
        }
      }
    },
    "yellowRibbon": {
      "type": "object",
      "title": "Yellow Ribbon Program",
      "description": "Chapter 10 — Captures Yellow Ribbon Program participation details. Conditional: shown only for Chapter 33, private institutions or out-of-state public, where a Yellow Ribbon Agreement is on file.",
      "additionalProperties": false,
      "required": ["isUsingYellowRibbon"],
      "properties": {
        "isUsingYellowRibbon": {
          "type": "boolean",
          "title": "Is student using Yellow Ribbon Program",
          "description": "Whether this student is participating in the Yellow Ribbon Program for this enrollment period."
        },
        "institutionContribution": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Institution Yellow Ribbon contribution",
          "description": "Dollar amount the institution is contributing through its Yellow Ribbon Agreement. Required when isUsingYellowRibbon is true."
        },
        "vaMatchAmount": {
          "$ref": "#/definitions/dollarAmount",
          "title": "VA Yellow Ribbon match amount",
          "description": "System-populated from Yellow Ribbon Agreement lookup. VA matches the institution contribution up to the agreement maximum."
        },
        "yellowRibbonAgreementFound": {
          "type": "boolean",
          "title": "Yellow Ribbon Agreement found for institution and academic year",
          "description": "System-set: true when the Yellow Ribbon Agreement lookup returns an active agreement for this facility code and academic year."
        },
        "agreementMaximumContribution": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Agreement maximum contribution",
          "description": "System-populated: the maximum institutional contribution allowed under the Yellow Ribbon Agreement for this institution and academic year."
        },
        "institutionContributionExceedsMax": {
          "type": "boolean",
          "title": "Institution contribution exceeds agreement maximum",
          "description": "System-set flag: true when institutionContribution exceeds agreementMaximumContribution.",
          "default": false
        }
      }
    },
    "housingAllowanceSummary": {
      "type": "object",
      "title": "Monthly Housing Allowance Summary",
      "description": "Chapter 11 — System-calculated MHA display. Read-only informational section for Chapter 33. No SCO data entry.",
      "additionalProperties": false,
      "properties": {
        "calculatedMonthlyHousingAllowance": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Calculated Monthly Housing Allowance",
          "description": "System-calculated MHA based on rate of pursuit and BAH E-5 with dependents for the institution's ZIP code."
        },
        "bahRateApplied": {
          "$ref": "#/definitions/dollarAmount",
          "title": "BAH E-5 with dependents rate applied",
          "description": "The BAH rate for E-5 with dependents at the institution's location used in the MHA calculation."
        },
        "mhaIsZeroDueToActiveDuty": {
          "type": "boolean",
          "title": "MHA is $0 due to active duty status",
          "description": "True if the student's active duty status results in a $0 MHA.",
          "default": false
        },
        "mhaIsZeroDueLowRateOfPursuit": {
          "type": "boolean",
          "title": "MHA is $0 due to rate of pursuit below 50%",
          "description": "True when the rate of pursuit is below 0.50, resulting in $0 MHA for Chapter 33.",
          "default": false
        },
        "bookStipendEligible": {
          "type": "boolean",
          "title": "Student is eligible for book stipend",
          "description": "True when the student qualifies for the Chapter 33 book stipend based on enrollment status."
        }
      }
    },
    "bookStipend": {
      "type": "object",
      "title": "Book Stipend",
      "description": "Chapter 12 — System-calculated book stipend display. Chapter 33 only. Read-only.",
      "additionalProperties": false,
      "properties": {
        "calculatedBookStipend": {
          "$ref": "#/definitions/dollarAmount",
          "title": "Calculated book stipend amount",
          "description": "System-calculated book stipend. Up to $1,000 per academic year, prorated for partial terms. $0 if rate of pursuit is 0."
        },
        "bookStipendProrated": {
          "type": "boolean",
          "title": "Book stipend is prorated",
          "description": "True when the book stipend has been prorated due to partial year or partial enrollment period.",
          "default": false
        }
      }
    },
    "certifyingOfficial": {
      "type": "object",
      "title": "Certifying Official Attestation",
      "description": "Chapter 13 — Captures certifying official contact information and attestation. Name and email are pre-filled from the authenticated profile.",
      "additionalProperties": false,
      "required": ["officialName", "officialTitle", "officialPhone", "officialEmail", "attestationSigned"],
      "properties": {
        "officialName": {
          "type": "string",
          "title": "Certifying official full name",
          "description": "Pre-filled from authenticated VA.gov profile. Read-only. This name appears on the certification.",
          "minLength": 2,
          "maxLength": 100,
          "pattern": "^[A-Za-z\\s'\\-]+$"
        },
        "officialTitle": {
          "type": "string",
          "title": "Certifying official title or role",
          "description": "The SCO's official title at the institution (e.g., 'School Certifying Official', 'Registrar', 'Veterans Services Coordinator').",
          "minLength": 2,
          "maxLength": 100
        },
        "officialPhone": {
          "$ref": "#/definitions/usPhone",
          "title": "Certifying official phone number",
          "description": "10-digit phone number for the certifying official. No dashes or spaces."
        },
        "officialEmail": {
          "$ref": "#/definitions/email",
          "title": "Certifying official email address",
          "description": "Pre-filled from authenticated VA.gov profile. Read-only. Used for VA correspondence regarding this certification."
        },
        "attestationSigned": {
          "type": "boolean",
          "title": "Attestation signed",
          "description": "The SCO certifies: 'I certify that the information provided is accurate and complete to the best of my knowledge; I am an authorized School Certifying Official for this institution.' Must be true to submit.",
          "enum": [true]
        }
      }
    },
    "submissionMetadata": {
      "type": "object",
      "title": "Submission Metadata",
      "description": "System-populated metadata recorded at submission time. Not shown to the SCO during the form flow.",
      "additionalProperties": false,
      "properties": {
        "submittedAt": {
          "type": "string",
          "format": "date-time",
          "title": "Submission timestamp",
          "description": "ISO 8601 UTC timestamp when the form was submitted."
        },
        "confirmationNumber": {
          "type": "string",
          "title": "Confirmation number",
          "description": "VA-assigned confirmation number returned after successful submission.",
          "maxLength": 50
        },
        "formVersion": {
          "type": "integer",
          "title": "Schema version",
          "description": "The version of the 22-1999 schema used for this submission.",
          "minimum": 0
        },
        "vaProfileId": {
          "type": "string",
          "title": "Authenticated user VA profile ID",
          "description": "The VA.gov profile ID of the authenticated SCO who submitted the form. Used for audit and deduplication.",
          "maxLength": 50
        },
        "ipAddress": {
          "type": "string",
          "title": "Submitter IP address",
          "description": "IP address of the client at submission time. Captured by vets-api; not stored in form data payload.",
          "maxLength": 45
        }
      }
    },
    "privacyAgreementAccepted": {
