// src/schemas/22-1999-schema.json
{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "VA Form 22-1999 Enrollment Certification",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "usPhone": {
      "type": "string",
      "pattern": "^[0-9]{10}$"
    },
    "ssn": {
      "type": "string",
      "pattern": "^[0-9]{9}$"
    },
    "vaFileNumber": {
      "type": "string",
      "pattern": "^[0-9]{7,9}$"
    },
    "facilityCode": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9]{8}$"
    },
    "personName": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "first": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[a-zA-Z\\-' ]+$"
        },
        "middle": {
          "type": "string",
          "maxLength": 30,
          "pattern": "^[a-zA-Z\\-' ]+$"
        },
        "last": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "pattern": "^[a-zA-Z\\-' ]+$"
        }
      },
      "required": ["first", "last"]
    },
    "currency": {
      "type": "number",
      "minimum": 0
    },
    "creditHours": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30
    }
  },
  "properties": {
    "certificationInformation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 3 — Certification Type selection (Original, Amended, Termination)",
      "properties": {
        "certificationType": {
          "type": "string",
          "enum": ["original", "amended", "termination"],
          "description": "The type of enrollment certification being submitted"
        }
      },
      "required": ["certificationType"]
    },
    "studentInformation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 4 — Student PII and GI Bill chapter selection",
      "properties": {
        "studentFirstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[a-zA-Z\\-' ]+$",
          "description": "Student's first name — letters, hyphens, apostrophes, spaces only"
        },
        "studentMiddleName": {
          "type": "string",
          "maxLength": 30,
          "pattern": "^[a-zA-Z\\-' ]+$",
          "description": "Student's middle name — optional"
        },
        "studentLastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "pattern": "^[a-zA-Z\\-' ]+$",
          "description": "Student's last name — letters, hyphens, apostrophes, spaces only"
        },
        "studentSSN": {
          "type": "string",
          "pattern": "^[0-9]{9}$",
          "description": "Student's Social Security Number — 9 digits, no dashes. Conditionally required: at least one of studentSSN or studentVAFileNumber must be present."
        },
        "studentVAFileNumber": {
          "type": "string",
          "pattern": "^[0-9]{7,9}$",
          "description": "Student's VA File Number — 7 to 9 digits. Conditionally required if SSN is not provided."
        },
        "studentDateOfBirth": {
          "type": "string",
          "format": "date",
          "description": "Student's date of birth in YYYY-MM-DD format. Must be at least 14 years before current date."
        },
        "giChapter": {
          "type": "string",
          "enum": ["ch33", "ch30", "ch1606", "ch35", "ch32"],
          "description": "GI Bill chapter the student is using: ch33=Post-9/11, ch30=MGIB Active Duty, ch1606=MGIB Selected Reserve, ch35=DEA, ch32=VEAP"
        }
      },
      "required": [
        "studentFirstName",
        "studentLastName",
        "studentDateOfBirth",
        "giChapter"
      ]
    },
    "institutionInformation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 5 — Institution and facility code confirmation",
      "properties": {
        "institutionName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Name of the VA-approved educational institution. Pre-populated from authenticated SCO session."
        },
        "facilityCode": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9]{8}$",
          "description": "8-character alphanumeric VA facility code assigned to the institution or campus. Validated against VA facility code lookup API."
        },
        "additionalFacilityCodes": {
          "type": "array",
          "description": "Additional campus facility codes if the institution has multiple locations",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9]{8}$"
          },
          "minItems": 0,
          "maxItems": 50
        }
      },
      "required": ["institutionName", "facilityCode"]
    },
    "programInformation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 6 — SAA-approved program details",
      "properties": {
        "programName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Name of the approved program of education as it appears on the SAA approval"
        },
        "cipCode": {
          "type": "string",
          "maxLength": 20,
          "pattern": "^[0-9]{2}\\.[0-9]{4}$",
          "description": "Classification of Instructional Programs (CIP) code or SAA approval reference — optional but validated if entered. Format: XX.XXXX"
        },
        "degreeLevel": {
          "type": "string",
          "enum": [
            "undergraduate",
            "graduate",
            "vocational",
            "ncd",
            "other"
          ],
          "description": "Degree or certificate level: undergraduate=Associate's/Bachelor's, graduate=Master's/Doctoral/Professional, vocational=Vocational/Technical certificate, ncd=Non-college degree, other=Other"
        },
        "isLicensingOrCertification": {
          "type": "boolean",
          "description": "Whether the program is a licensing or certification preparatory program. Drives MISSION Act restriction display."
        }
      },
      "required": ["programName", "degreeLevel", "isLicensingOrCertification"]
    },
    "enrollmentPeriod": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 7 — Training period begin and end dates",
      "properties": {
        "enrollmentBeginDate": {
          "type": "string",
          "format": "date",
          "description": "Training period begin date in YYYY-MM-DD format. May not be more than 120 days in the future."
        },
        "enrollmentEndDate": {
          "type": "string",
          "format": "date",
          "description": "Training period end date in YYYY-MM-DD format. Must be on or after enrollmentBeginDate. May not be more than 1 year in the past."
        },
        "priorEnrollmentBeginDate": {
          "type": "string",
          "format": "date",
          "description": "For Amended or Termination certifications only — original enrollment period begin date"
        },
        "priorEnrollmentEndDate": {
          "type": "string",
          "format": "date",
          "description": "For Amended or Termination certifications only — original enrollment period end date"
        }
      },
      "required": ["enrollmentBeginDate", "enrollmentEndDate"]
    },
    "creditHoursTrainingTime": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 8 — Credit/clock hours and training-time classification",
      "properties": {
        "creditHoursCertified": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30,
          "description": "Number of credit or clock hours certified for this enrollment period"
        },
        "institutionFullTimeHours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30,
          "description": "The institution's standard full-time credit hour threshold (e.g., 12 credits per term)"
        },
        "trainingTime": {
          "type": "string",
          "enum": [
            "full-time",
            "three-quarter-time",
            "half-time",
            "less-than-half-time"
          ],
          "description": "VA training-time classification based on credit hours relative to full-time standard"
        },
        "rateOfPursuit": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Rate of pursuit percentage used for Chapter 33 Monthly Housing Allowance calculation. Computed value (creditHoursCertified / institutionFullTimeHours * 100), stored for audit."
        }
      },
      "required": ["creditHoursCertified", "institutionFullTimeHours", "trainingTime"]
    },
    "tuitionAndFees": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 9 — Tuition and mandatory fees (Chapter 33 only). This section is conditionally required when giChapter equals 'ch33'.",
      "properties": {
        "totalTuitionCharged": {
          "type": "number",
          "minimum": 0,
          "description": "Total tuition charged to the student for the enrollment period in US dollars"
        },
        "mandatoryFeesCharged": {
          "type": "number",
          "minimum": 0,
          "description": "Mandatory fees charged to the student for the enrollment period in US dollars"
        },
        "isYellowRibbonParticipant": {
          "type": "boolean",
          "description": "Whether the student is participating in the Yellow Ribbon Program for this enrollment period"
        },
        "yellowRibbonSchoolContribution": {
          "type": "number",
          "minimum": 0,
          "description": "School's Yellow Ribbon Program contribution amount in US dollars. Conditionally required when isYellowRibbonParticipant is true."
        }
      },
      "required": ["totalTuitionCharged", "mandatoryFeesCharged", "isYellowRibbonParticipant"]
    },
    "amendmentDetails": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 10 — Amendment details. Conditionally required when certificationType is 'amended' or 'termination'.",
      "properties": {
        "originalCertificationReferenceNumber": {
          "type": "string",
          "maxLength": 30,
          "description": "Reference number of the original certification being amended — optional if known"
        },
        "reasonForAmendment": {
          "type": "string",
          "enum": [
            "student-added-courses",
            "student-dropped-courses",
            "student-withdrew",
            "student-returned-from-leave",
            "training-time-change",
            "other"
          ],
          "description": "The reason the certification is being amended or terminated"
        },
        "effectiveDateOfChange": {
          "type": "string",
          "format": "date",
          "description": "Effective date of the enrollment change in YYYY-MM-DD format"
        },
        "explanationOfChange": {
          "type": "string",
          "maxLength": 500,
          "description": "Explanation of the enrollment change. Required when reasonForAmendment is 'other'; optional for all other reasons."
        },
        "fieldsBeingChanged": {
          "type": "object",
          "additionalProperties": false,
          "description": "Checkbox group indicating which fields are changing in this amendment",
          "properties": {
            "creditHours": {
              "type": "boolean",
              "description": "Credit hours are changing"
            },
            "trainingTime": {
              "type": "boolean",
              "description": "Training time classification is changing"
            },
            "tuitionFees": {
              "type": "boolean",
              "description": "Tuition or fees amounts are changing"
            },
            "enrollmentDates": {
              "type": "boolean",
              "description": "Enrollment begin or end dates are changing"
            },
            "program": {
              "type": "boolean",
              "description": "Program of education is changing"
            }
          }
        }
      },
      "required": ["reasonForAmendment", "effectiveDateOfChange"]
    },
    "activeDutyStatus": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 11 — Active duty status confirmation. Conditionally required when giChapter equals 'ch33'.",
      "properties": {
        "isStudentOnActiveDuty": {
          "type": "boolean",
          "description": "Whether the student is currently on active duty. Drives MHA eligibility: active duty students receive $0 Monthly Housing Allowance under Chapter 33."
        }
      },
      "required": ["isStudentOnActiveDuty"]
    },
    "scoCertification": {
      "type": "object",
      "additionalProperties": false,
      "description": "Screen 12 — SCO certification statement and identifying information",
      "properties": {
        "scoName": {
          "type": "object",
          "additionalProperties": false,
          "description": "School Certifying Official's full name — pre-populated from authenticated session",
          "properties": {
            "first": {
              "type": "string",
              "minLength": 1,
              "maxLength": 30,
              "pattern": "^[a-zA-Z\\-' ]+$"
            },
            "middle": {
              "type": "string",
              "maxLength": 30,
              "pattern": "^[a-zA-Z\\-' ]+$"
            },
            "last": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40,
              "pattern": "^[a-zA-Z\\-' ]+$"
            }
          },
          "required": ["first", "last"]
        },
        "scoTitle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "SCO's official title or position at the institution"
        },
        "scoPhoneNumber": {
          "type": "string",
          "pattern": "^[0-9]{10}$",
          "description": "SCO's contact phone number — 10 digits, no dashes or formatting"
        },
        "scoPhoneExtension": {
          "type": "string",
          "maxLength": 10,
          "pattern": "^[0-9]{1,10}$",
          "description": "SCO's phone extension — optional"
        },
        "certificationStatement": {
          "type": "boolean",
          "enum": [true],
          "description": "SCO attestation that the submitted information is true and correct to the best of their knowledge. Must be true (checked) to submit."
        }
      },
      "required": [
        "scoName",
        "scoTitle",
        "scoPhoneNumber",
        "certificationStatement"
      ]
    },
    "submissionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "description": "System-generated metadata captured at submission time — not user-entered",
      "properties": {
        "formVersion": {
          "type": "string",
          "description": "Version of the 22-1999 form schema used at time of submission",
          "maxLength": 20
        },
        "submittedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the certification was submitted"
        },
        "confirmationNumber": {
          "type": "string",
          "maxLength": 50,
          "description": "VA-assigned confirmation number returned from the Education Benefits Submissions endpoint"
        },
        "scoPrimaryFacilityCode": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9]{8}$",
          "description": "Primary facility code from the authenticated SCO session at time of submission — for audit trail"
        },
        "scoUserId": {
          "type": "string",
          "maxLength": 100,
          "description": "Opaque identifier for the authenticated SCO user from the identity provider — for audit trail"
        },
        "applicationVersion": {
          "type": "string",
          "maxLength": 20,
          "description": "Version of the vets-website application at time of submission"
        }
      }
    }
  },
  "required": [
    "certificationInformation",
    "studentInformation",
    "institutionInformation",
    "programInformation",
    "enrollmentPeriod",
    "creditHoursTrainingTime",
    "scoCertification"
  ]
}