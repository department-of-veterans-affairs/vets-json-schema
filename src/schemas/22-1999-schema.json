// src/schemas/22-1999-schema.json
{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "VA Form 22-1999 Enrollment Certification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scoAuthorization",
    "certificationTypeInfo",
    "institutionInformation",
    "studentIdentification",
    "benefitChapter",
    "enrollmentPeriod",
    "programInformation",
    "creditHoursTrainingTime",
    "scoCertification"
  ],
  "properties": {

    "scoAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scoAttestation"],
      "properties": {
        "scoUserId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "VA-assigned SCO User ID; may be pre-populated from authenticated session"
        },
        "scoAttestation": {
          "type": "boolean",
          "description": "SCO confirms they are a designated certifying official for the institution; must be true to proceed"
        }
      }
    },

    "certificationTypeInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["certificationType"],
      "properties": {
        "certificationType": {
          "type": "string",
          "enum": ["original", "amended", "termination"],
          "description": "Type of certification being submitted"
        }
      }
    },

    "institutionInformation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facilityCode",
        "institutionName",
        "addressLine1",
        "city",
        "state",
        "zipCode",
        "institutionType",
        "yellowRibbonParticipant"
      ],
      "properties": {
        "facilityCode": {
          "type": "string",
          "pattern": "^\\d{8}$",
          "minLength": 8,
          "maxLength": 8,
          "description": "VA-assigned 8-digit numeric facility code"
        },
        "institutionName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Institution name; may be auto-populated read-only from facility code lookup"
        },
        "addressLine1": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Institution street address line 1"
        },
        "addressLine2": {
          "type": "string",
          "maxLength": 100,
          "description": "Institution street address line 2 (optional)"
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Institution city"
        },
        "state": {
          "type": "string",
          "enum": [
            "AL","AK","AZ","AR","CA","CO","CT","DE","DC","FL","GA","HI",
            "ID","IL","IN","IA","KS","KY","LA","ME","MD","MA","MI","MN",
            "MS","MO","MT","NE","NV","NH","NJ","NM","NY","NC","ND","OH",
            "OK","OR","PA","RI","SC","SD","TN","TX","UT","VT","VA","WA",
            "WV","WI","WY","AS","GU","MP","PR","VI","FM","MH","PW"
          ],
          "description": "Two-letter US state or territory abbreviation"
        },
        "zipCode": {
          "type": "string",
          "pattern": "^\\d{5}(-\\d{4})?$",
          "minLength": 5,
          "maxLength": 10,
          "description": "US ZIP code, 5-digit or ZIP+4 format"
        },
        "institutionType": {
          "type": "string",
          "enum": ["public", "privateNonProfit", "proprietary"],
          "description": "Type of institution: Public, Private Non-Profit, or Proprietary/For-Profit"
        },
        "yellowRibbonParticipant": {
          "type": "boolean",
          "description": "Whether institution has a Yellow Ribbon Agreement on file with VA"
        }
      }
    },

    "studentIdentification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identifierType",
        "studentIdentifier",
        "studentFirstName",
        "studentLastName",
        "studentDateOfBirth"
      ],
      "properties": {
        "identifierType": {
          "type": "string",
          "enum": ["ssn", "vaFileNumber"],
          "description": "Whether the student is identified by SSN or VA File Number"
        },
        "studentIdentifier": {
          "type": "string",
          "maxLength": 30,
          "description": "SSN (9 digits, masked) or VA File Number (alphanumeric); format validated conditionally by identifierType"
        },
        "studentSsn": {
          "type": "string",
          "pattern": "^\\d{9}$",
          "minLength": 9,
          "maxLength": 9,
          "description": "Student Social Security Number — 9 digits, no dashes; used when identifierType = ssn"
        },
        "studentVaFileNumber": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9]{5,10}$",
          "minLength": 5,
          "maxLength": 10,
          "description": "VA File Number — alphanumeric; used when identifierType = vaFileNumber"
        },
        "studentFirstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "Student legal first name"
        },
        "studentMiddleName": {
          "type": "string",
          "maxLength": 50,
          "description": "Student legal middle name (optional)"
        },
        "studentLastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "Student legal last name"
        },
        "studentSuffix": {
          "type": "string",
          "enum": ["Jr.", "Sr.", "II", "III", "IV"],
          "description": "Student name suffix (optional)"
        },
        "studentDateOfBirth": {
          "type": "string",
          "format": "date",
          "description": "Student date of birth in YYYY-MM-DD format"
        },
        "studentEmailAddress": {
          "type": "string",
          "format": "email",
          "maxLength": 256,
          "description": "Student email address for Veteran status notification (optional)"
        }
      }
    },

    "benefitChapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chapter"],
      "properties": {
        "chapter": {
          "type": "string",
          "enum": ["chapter33", "chapter30", "chapter1606", "chapter35", "chapter32"],
          "description": "GI Bill chapter under which student is being certified; Phase 1 enforces chapter33 only"
        },
        "activeDutyStatus": {
          "type": "boolean",
          "description": "Whether student is currently on active duty; shown and required only when chapter = chapter33 (active duty = $0 MHA)"
        }
      }
    },

    "enrollmentPeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trainingPeriodBeginDate", "trainingPeriodEndDate"],
      "properties": {
        "trainingPeriodBeginDate": {
          "type": "string",
          "format": "date",
          "description": "Training period begin date in YYYY-MM-DD format"
        },
        "trainingPeriodEndDate": {
          "type": "string",
          "format": "date",
          "description": "Training period end date in YYYY-MM-DD format"
        },
        "priorCertificationReferenceNumber": {
          "type": "string",
          "maxLength": 50,
          "description": "Prior certification reference number; shown only for Amended and Termination types"
        },
        "effectiveDateOfChange": {
          "type": "string",
          "format": "date",
          "description": "Effective date of change in YYYY-MM-DD format; shown only for Amended and Termination types"
        }
      }
    },

    "programInformation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["programMajorName", "degreeCertificateLevel", "standardLengthOfProgram"],
      "properties": {
        "programMajorName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Approved program or major name; must be SAA-approved at this facility"
        },
        "degreeCertificateLevel": {
          "type": "string",
          "enum": [
            "nonCollegeDegree",
            "associate",
            "bachelors",
            "masters",
            "doctoral",
            "certificate",
            "vocationalTechnical"
          ],
          "description": "Degree or certificate level of the enrolled program"
        },
        "standardLengthOfProgram": {
          "type": "string",
          "enum": [
            "1semester",
            "1year",
            "2years",
            "3years",
            "4years",
            "other"
          ],
          "description": "Standard length of the approved program"
        },
        "standardLengthOther": {
          "type": "string",
          "maxLength": 100,
          "description": "Description of program length when standardLengthOfProgram = 'other'"
        },
        "specialProgramFlags": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "licensingCertificationProgram": {
              "type": "boolean",
              "description": "Program is a Licensing or Certification program (MISSION Act restrictions apply)"
            },
            "correspondence": {
              "type": "boolean",
              "description": "Program is a Correspondence program"
            },
            "independentStudy": {
              "type": "boolean",
              "description": "Program includes Independent Study"
            },
            "coopTraining": {
              "type": "boolean",
              "description": "Program includes Co-op Training"
            }
          }
        }
      }
    },

    "creditHoursTrainingTime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "creditType",
        "hoursEnrolled",
        "fullTimeStandard",
        "trainingTimeClassification"
      ],
      "properties": {
        "creditType": {
          "type": "string",
          "enum": ["creditHours", "clockHours"],
          "description": "Whether enrollment is measured in credit hours or clock hours"
        },
        "hoursEnrolled": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30,
          "description": "Number of credit or clock hours enrolled this term (max 30 for credit hours)"
        },
        "fullTimeStandard": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30,
          "description": "Institution's full-time credit or clock hour standard (e.g., 12 for undergraduate)"
        },
        "trainingTimeClassification": {
          "type": "string",
          "enum": ["fullTime", "threeQuarterTime", "halfTime", "lessThanHalfTime"],
          "description": "Training time classification; auto-suggested from rate of pursuit calculation but SCO must confirm"
        },
        "rateOfPursuit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Calculated read-only field: hoursEnrolled / fullTimeStandard * 100, rounded to nearest integer"
        }
      }
    },

    "tuitionFees": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tuitionCharged", "mandatoryFeesCharged", "nonResidentStudent"],
      "properties": {
        "tuitionCharged": {
          "type": "number",
          "minimum": 0,
          "description": "Tuition charged this term in US dollars; Chapter 33 only"
        },
        "mandatoryFeesCharged": {
          "type": "number",
          "minimum": 0,
          "description": "Mandatory fees charged this term in US dollars"
        },
        "totalTuitionAndFees": {
          "type": "number",
          "minimum": 0,
          "description": "Calculated read-only sum of tuitionCharged + mandatoryFeesCharged"
        },
        "itemizedFeeDescription": {
          "type": "string",
          "maxLength": 2000,
          "description": "Required itemization of each mandatory fee type and amount if mandatoryFeesCharged > 0"
        },
        "nonResidentStudent": {
          "type": "boolean",
          "description": "Whether student is a non-resident/out-of-state student at a public institution (VA pays in-state rate)"
        }
      }
    },

    "yellowRibbon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schoolYellowRibbonContribution"],
      "properties": {
        "schoolYellowRibbonContribution": {
          "type": "number",
          "minimum": 0,
          "description": "School's Yellow Ribbon contribution this term in US dollars; validated against Agreement maximum"
        },
        "vaYellowRibbonMatchingAmount": {
          "type": "number",
          "minimum": 0,
          "description": "Calculated read-only: VA matching amount equal to school contribution up to Agreement maximum"
        },
        "yellowRibbonAgreementReferenceNumber": {
          "type": "string",
          "maxLength": 50,
          "description": "Yellow Ribbon Agreement reference number for SCO records (optional)"
        }
      }
    },

    "priorCertificationChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["typesOfChange", "changeDescription"],
      "properties": {
        "typesOfChange": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "addedCourses": {
              "type": "boolean",
              "description": "Student added courses"
            },
            "droppedCourses": {
              "type": "boolean",
              "description": "Student dropped courses"
            },
            "trainingTimeReclassification": {
              "type": "boolean",
              "description": "Training time reclassification"
            },
            "tuitionFeeCorrection": {
              "type": "boolean",
              "description": "Tuition or fee correction"
            },
            "programChange": {
              "type": "boolean",
              "description": "Change in program of education"
            },
            "other": {
              "type": "boolean",
              "description": "Other type of change"
            }
          }
        },
        "changeDescription": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "description": "Required detailed description of what changed from the prior certification"
        },
        "courseChangeDate": {
          "type": "string",
          "format": "date",
          "description": "Date student added or dropped courses in YYYY-MM-DD format; required if addedCourses or droppedCourses is true"
        },
        "updatedHoursEnrolled": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30,
          "description": "Updated credit or clock hours enrolled after change; shown if hours changed"
        },
        "updatedTrainingTimeClassification": {
          "type": "string",
          "enum": ["fullTime", "threeQuarterTime", "halfTime", "lessThanHalfTime"],
          "description": "Updated training time classification after amendment"
        },
        "mitigatingCircumstancesApply": {
          "type": "boolean",
          "description": "Whether mitigating circumstances apply to a reduction or drop"
        },
        "mitigatingCircumstancesDescription": {
          "type": "string",
          "maxLength": 2000,
          "description": "Description of mitigating circumstances; required if mitigatingCircumstancesApply = true"
        }
      }
    },

    "terminationInformation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "terminationReason",
        "lastDateOfAttendance",
        "nonPunitiveGradesReceived",
        "mitigatingCircumstancesApply"
      ],
      "properties": {
        "terminationReason": {
          "type": "string",
          "enum": [
            "studentWithdrew",
            "studentExpelled",
            "didNotReturnFromBreak",
            "changeInTrainingTime",
            "unsatisfactoryProgress",
            "graduatedEarly",
            "militaryDeployment",
            "other"
          ],
          "description": "Reason for termination or reduction of enrollment"
        },
        "lastDateOfAttendance": {
          "type": "string",
          "format": "date",
          "description": "Student's last date of attendance in YYYY-MM-DD format"
        },
        "officialWithdrawalDate": {
          "type": "string",
          "format": "date",
          "description": "Official withdrawal date if different from last date of attendance in YYYY-MM-DD format (optional)"
        },
        "nonPunitiveGradesReceived": {
          "type": "boolean",
          "description": "Whether student received any non-punitive grades (W, I, NC) this term"
        },
        "mitigatingCircumstancesApply": {
          "type": "boolean",
          "description": "Whether mitigating circumstances apply to the termination or reduction"
        },
        "mitigatingCircumstancesDescription": {
          "type": "string",
          "maxLength": 2000,
          "description": "Description of mitigating circumstances; required if mitigatingCircumstancesApply = true"
        }
      }
    },

    "scoCertification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scoFirstName",
        "scoLastName",
        "scoTitle",
        "scoPhoneNumber",
        "scoEmailAddress",
        "certificationAttestation",
        "dateOfCertification"
      ],
      "properties": {
        "scoFirstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "SCO certifier first name; pre-populated from authenticated session"
        },
        "scoLastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "SCO certifier last name; pre-populated from authenticated session"
        },
        "scoTitle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "SCO title or position at the institution"
        },
        "scoPhoneNumber": {
          "type": "string",
          "pattern": "^\\d{10}$",
          "minLength": 10,
          "maxLength": 10,
          "description": "SCO phone number — 10 digits, no dashes or formatting"
        },
        "scoEmailAddress": {
          "type": "string",
          "format": "email",
          "maxLength": 256,
          "description": "SCO email address; pre-populated from authenticated session"
        },
        "scoFaxNumber": {
          "type": "string",
          "pattern": "^\\d{10}$",
          "minLength": 10,
          "maxLength": 10,
          "description": "SCO fax number — 10 digits, no dashes or formatting (optional)"
        },
        "certificationAttestation": {
          "type": "boolean",
          "description": "SCO certifies that the information is true and correct and understands 18 U.S.C. § 1001; must be true to submit"
        },
        "dateOfCertification": {
          "type": "string",
          "format": "date",
          "description": "Date of certification in YYYY-MM-DD format; defaults to today's date"
        }
      }
    }

  }
}