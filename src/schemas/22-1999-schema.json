// src/schemas/22-1999-schema.json
{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "VA Form 22-1999 Enrollment Certification",
  "description": "Schema for VA Form 22-1999 — Enrollment Certification (Paper-Fallback Digital Submission Channel). Submitted by School Certifying Officials for foreign schools, non-Title IV institutions, OJT/apprenticeship programs, and institutions experiencing VA-ONCE outages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "certifierInfo",
    "institutionInfo",
    "studentInfo",
    "benefitChapter",
    "programInfo",
    "enrollmentPeriod",
    "creditClockHours",
    "advancePay",
    "certifierSignature",
    "privacyAgreementAccepted"
  ],
  "definitions": {
    "address": {
      "type": "object",
      "additionalProperties": false,
      "required": ["street", "city"],
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "street2": {
          "type": "string",
          "maxLength": 100
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "state": {
          "type": "string",
          "maxLength": 50
        },
        "postalCode": {
          "type": "string",
          "maxLength": 20
        },
        "country": {
          "type": "string",
          "maxLength": 100
        }
      }
    },
    "usAddress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["street", "city", "state", "postalCode"],
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "street2": {
          "type": "string",
          "maxLength": 100
        },
        "city": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "state": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2,
          "pattern": "^[A-Z]{2}$"
        },
        "postalCode": {
          "type": "string",
          "pattern": "^\\d{5}(-\\d{4})?$"
        }
      }
    },
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "ssn": {
      "type": "string",
      "pattern": "^\\d{3}-\\d{2}-\\d{4}$"
    },
    "phone": {
      "type": "string",
      "pattern": "^\\d{10}$"
    },
    "email": {
      "type": "string",
      "format": "email",
      "minLength": 5,
      "maxLength": 254
    },
    "currencyAmount": {
      "type": "number",
      "minimum": 0,
      "maximum": 999999.99
    }
  },
  "properties": {
    "certifierInfo": {
      "type": "object",
      "description": "Chapter 1 — Certifying Official Identity. SCO personal and contact information.",
      "additionalProperties": false,
      "required": [
        "firstName",
        "lastName",
        "title",
        "email",
        "phone",
        "scoRegistrationNumber"
      ],
      "properties": {
        "firstName": {
          "type": "string",
          "description": "SCO first name, pre-filled from authenticated session where available.",
          "minLength": 1,
          "maxLength": 50
        },
        "lastName": {
          "type": "string",
          "description": "SCO last name, pre-filled from authenticated session where available.",
          "minLength": 1,
          "maxLength": 50
        },
        "middleInitial": {
          "type": "string",
          "description": "SCO middle initial (optional).",
          "maxLength": 1,
          "pattern": "^[A-Za-z]$"
        },
        "title": {
          "type": "string",
          "description": "SCO job title at the institution (e.g., Registrar, Financial Aid Officer).",
          "minLength": 1,
          "maxLength": 100
        },
        "email": {
          "$ref": "#/definitions/email",
          "description": "SCO institutional email address. Must be an official school or employer email, not a personal email provider."
        },
        "phone": {
          "$ref": "#/definitions/phone",
          "description": "SCO daytime phone number, 10 digits, no formatting. Area code required."
        },
        "phoneExtension": {
          "type": "string",
          "description": "Phone extension (optional).",
          "maxLength": 10,
          "pattern": "^\\d{1,10}$"
        },
        "scoRegistrationNumber": {
          "type": "string",
          "description": "VA-assigned School Certifying Official registration number from VA-ONCE profile or SCO authorization letter.",
          "minLength": 6,
          "maxLength": 12,
          "pattern": "^[A-Z0-9]{6,12}$"
        }
      }
    },
    "institutionInfo": {
      "type": "object",
      "description": "Chapter 1 — Institution Identity. School Facility Code lookup and institution details.",
      "additionalProperties": false,
      "required": [
        "schoolFacilityCode",
        "institutionName",
        "institutionType",
        "institutionAddress"
      ],
      "properties": {
        "schoolFacilityCode": {
          "type": "string",
          "description": "VA-assigned School Facility Code (SFC). Used for SFC master list lookup to auto-populate institution fields.",
          "minLength": 8,
          "maxLength": 8,
          "pattern": "^\\d{8}$"
        },
        "sfcLookupSucceeded": {
          "type": "boolean",
          "description": "True when SFC lookup returned a valid match and auto-populated institution fields. False/absent when SCO entered fields manually."
        },
        "institutionName": {
          "type": "string",
          "description": "Full name of the educational institution. Pre-populated from SFC lookup when available.",
          "minLength": 1,
          "maxLength": 200
        },
        "institutionType": {
          "type": "string",
          "description": "Type of educational institution. Drives conditional page routing (OJT_APPRENTICESHIP shows ojtDetails chapter).",
          "enum": [
            "IHL",
            "OJT_APPRENTICESHIP",
            "NON_COLLEGE_DEGREE",
            "FLIGHT",
            "NATIONAL_EXAM",
            "FOREIGN_SCHOOL"
          ]
        },
        "institutionAddress": {
          "type": "object",
          "description": "Institution address. Label and required fields differ for foreign schools vs. domestic institutions.",
          "additionalProperties": false,
          "required": ["street", "city"],
          "properties": {
            "street": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "street2": {
              "type": "string",
              "maxLength": 100
            },
            "city": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "state": {
              "type": "string",
              "description": "U.S. state abbreviation for domestic institutions, or state/province name for foreign schools.",
              "maxLength": 50
            },
            "country": {
              "type": "string",
              "description": "Country name. Required when institutionType is FOREIGN_SCHOOL.",
              "maxLength": 100
            },
            "postalCode": {
              "type": "string",
              "description": "ZIP code for domestic institutions; postal code for foreign schools. Label adjusts by country.",
              "maxLength": 20
            }
          }
        },
        "vaRegionalProcessingOffice": {
          "type": "string",
          "description": "VA Regional Processing Office auto-populated based on institution state/country using RPO routing table. Read-only display field.",
          "enum": [
            "BUFFALO",
            "MUSKOGEE",
            "ST_LOUIS"
          ]
        }
      }
    },
    "studentInfo": {
      "type": "object",
      "description": "Chapter 2 — Student Identification. SSN or VA file number, name, and date of birth for MPI lookup.",
      "additionalProperties": false,
      "required": [
        "studentIdentifierType",
        "firstName",
        "lastName",
        "dateOfBirth"
      ],
      "properties": {
        "studentIdentifierType": {
          "type": "string",
          "description": "Whether the SCO is identifying the student by SSN or VA File Number.",
          "enum": [
            "SSN",
            "VA_FILE_NUMBER"
          ]
        },
        "ssn": {
          "$ref": "#/definitions/ssn",
          "description": "Student Social Security Number in XXX-XX-XXXX format. Required when studentIdentifierType is SSN."
        },
        "vaFileNumber": {
          "type": "string",
          "description": "VA File Number. Required when studentIdentifierType is VA_FILE_NUMBER.",
          "minLength": 7,
          "maxLength": 9,
          "pattern": "^[A-Z]?\\d{7,9}$"
        },
        "firstName": {
          "type": "string",
          "description": "Student first name.",
          "minLength": 1,
          "maxLength": 50
        },
        "middleInitial": {
          "type": "string",
          "description": "Student middle initial (optional).",
          "maxLength": 1,
          "pattern": "^[A-Za-z]$"
        },
        "lastName": {
          "type": "string",
          "description": "Student last name.",
          "minLength": 1,
          "maxLength": 50
        },
        "suffix": {
          "type": "string",
          "description": "Student name suffix (optional).",
          "enum": [
            "Jr.",
            "Sr.",
            "II",
            "III",
            "IV",
            "V"
          ]
        },
        "dateOfBirth": {
          "$ref": "#/definitions/date",
          "description": "Student date of birth in YYYY-MM-DD format."
        },
        "mpiLookupSucceeded": {
          "type": "boolean",
          "description": "True when MPI lookup returned an active benefits record for this student. Drives display of entitlement balance info."
        },
        "mpiEntitlementBalance": {
          "type": "object",
          "description": "Student entitlement balance data returned from MPI lookup. Read-only display. Not submitted by user.",
          "additionalProperties": false,
          "properties": {
            "remainingEntitlementMonths": {
              "type": "integer",
              "minimum": 0,
              "maximum": 36
            },
            "remainingEntitlementDays": {
              "type": "integer",
              "minimum": 0,
              "maximum": 30
            }
          }
        }
      }
    },
    "benefitChapter": {
      "type": "string",
      "description": "Chapter 2 — GI Bill chapter the student is using. This is the primary branching field that drives conditional display of subsequent payment/tuition fields.",
      "enum": [
        "chapter33",
        "chapter30",
        "chapter35",
        "chapter1606",
        "chapter1607",
        "veap"
      ]
    },
    "programInfo": {
      "type": "object",
      "description": "Chapter 3 — Educational Program Details. Program name, degree objective, CIP code, approval number, and full-time credit hour standard.",
      "additionalProperties": false,
      "required": [
        "programName",
        "degreeObjective",
        "institutionalFullTimeCreditHourStandard",
        "creditOrClockHours"
      ],
      "properties": {
        "programName": {
          "type": "string",
          "description": "Name of the educational or training program.",
          "minLength": 1,
          "maxLength": 200
        },
        "degreeObjective": {
          "type": "string",
          "description": "Degree or certificate objective for the student's program.",
          "enum": [
            "ASSOCIATE",
            "BACHELOR",
            "MASTER",
            "DOCTORAL",
            "CERTIFICATE",
            "VOCATIONAL_CERTIFICATE",
            "OJT",
            "APPRENTICESHIP",
            "FLIGHT",
            "LICENSING_CERTIFICATION_EXAM",
            "CORRESPONDENCE"
          ]
        },
        "cipCode": {
          "type": "string",
          "description": "Classification of Instructional Programs code (6-digit). Optional but recommended.",
          "pattern": "^\\d{2}\\.\\d{4}$"
        },
        "vaProgramApprovalNumber": {
          "type": "string",
          "description": "VA program approval number assigned by the State Approving Agency.",
          "maxLength": 50
        },
        "institutionalFullTimeCreditHourStandard": {
          "type": "integer",
          "description": "The number of credit hours the institution considers full-time for this program type. Required for training time percentage calculation.",
          "minimum": 1,
          "maximum": 30
        },
        "creditOrClockHours": {
          "type": "string",
          "description": "Whether the program measures enrollment in credit hours or clock hours. Drives conditional display of credit/clock hour fields.",
          "enum": [
            "CREDIT_HOURS",
            "CLOCK_HOURS"
          ]
        }
      }
    },
    "enrollmentPeriod": {
      "type": "object",
      "description": "Chapter 3 — Enrollment Period Dates. Begin and end dates of the enrollment period being certified.",
      "additionalProperties": false,
      "required": [
        "enrollmentBeginDate",
        "enrollmentEndDate",
        "certificationTypeSelection"
      ],
      "properties": {
        "enrollmentBeginDate": {
          "$ref": "#/definitions/date",
          "description": "First date of class, not registration date. In YYYY-MM-DD format."
        },
        "enrollmentEndDate": {
          "$ref": "#/definitions/date",
          "description": "Last scheduled day of class for the term. In YYYY-MM-DD format."
        },
        "certificationTypeSelection": {
          "type": "string",
          "description": "Whether this is an initial certification or an amendment/correction. Drives conditional display of amendmentInfo chapter.",
          "enum": [
            "initial",
            "amendment"
          ]
        },
        "termName": {
          "type": "string",
          "description": "Term name or identifier (e.g., 'Fall 2025') to help match to academic calendar on file.",
          "maxLength": 100
        }
      }
    },
    "creditClockHours": {
      "type": "object",
      "description": "Chapter 3 — Credit or Clock Hours Enrolled. Hours certified and course type breakdown.",
      "additionalProperties": false,
      "properties": {
        "creditHoursEnrolled": {
          "type": "integer",
          "description": "Number of credit hours the student is enrolled in for this enrollment period. Shown when creditOrClockHours is CREDIT_HOURS.",
          "minimum": 0,
          "maximum": 30
        },
        "clockHoursPerWeek": {
          "type": "integer",
          "description": "Number of clock hours per week the student attends training. Shown when creditOrClockHours is CLOCK_HOURS.",
          "minimum": 0,
          "maximum": 168
        },
        "clockHoursForPeriod": {
          "type": "integer",
          "description": "Total clock hours for the entire enrollment period. Shown when creditOrClockHours is CLOCK_HOURS.",
          "minimum": 0,
          "maximum": 9999
        },
        "courseTypes": {
          "type": "array",
          "description": "Course types included in this enrollment certification. Multi-select.",
          "items": {
            "type": "string",
            "enum": [
              "REGULAR_DEGREE",
              "REMEDIAL_DEFICIENCY",
              "INDEPENDENT_STUDY",
              "ONLINE_DISTANCE",
              "WORK_STUDY"
            ]
          },
          "uniqueItems": true,
          "minItems": 0
        },
        "onlineCreditHours": {
          "type": "integer",
          "description": "Number of online/distance learning credit hours within the total enrolled hours. Relevant for Chapter 33 MHA calculation.",
          "minimum": 0,
          "maximum": 30
        },
        "calculatedTrainingTimePercent": {
          "type": "integer",
          "description": "Computed training time percentage: creditHoursEnrolled / institutionalFullTimeCreditHourStandard × 100. Derived field — not user input. Stored for routing logic (gates housingAllowance chapter at >= 50%). Values are VA training time tiers.",
          "enum": [
            100,
            75,
            50,
            40
          ]
        },
        "calculatedTrainingTimeLabel": {
          "type": "string",
          "description": "Human-readable training time label derived from calculatedTrainingTimePercent.",
          "enum": [
            "FULL_TIME",
            "THREE_QUARTER_TIME",
            "HALF_TIME",
            "LESS_THAN_HALF_TIME"
          ]
        }
      }
    },
    "tuitionFees": {
      "type": "object",
      "description": "Chapter 4 — Tuition and Fees. Required for Chapter 33 only. Conditionally absent for all other benefit chapters.",
      "additionalProperties": false,
      "required": [
        "tuitionCharges",
        "tuitionRateType",
        "mandatoryFees",
        "totalTuitionAndFeesCertified"
      ],
      "properties": {
        "tuitionCharges": {
          "$ref": "#/definitions/currencyAmount",
          "description": "Total tuition charges for the enrollment period (in-state or out-of-state as applicable)."
        },
        "tuitionRateType": {
          "type": "string",
          "description": "Whether the tuition rate is in-state or out-of-state.",
          "enum": [
            "IN_STATE",
            "OUT_OF_STATE",
            "NOT_APPLICABLE"
          ]
        },
        "mandatoryFees": {
          "$ref": "#/definitions/currencyAmount",
          "description": "Itemized total of all mandatory fees charged to the student."
        },
        "feeDescription": {
          "type": "string",
          "description": "Description listing each mandatory fee by name and amount (e.g., 'Student Activity Fee $150, Technology Fee $75').",
          "maxLength": 2000
        },
        "yellowRibbonContribution": {
          "$ref": "#/definitions/currencyAmount",
          "description": "Yellow Ribbon Program contribution from the institution. Enter 0 if not participating."
        },
        "totalTuitionAndFeesCertified": {
          "$ref": "#/definitions/currencyAmount",
          "description": "Total tuition and fees being certified for VA payment. Should equal tuitionCharges + mandatoryFees minus any applicable exclusions."
        },
        "feeExclusionsApplied": {
          "type": "array",
          "description": "Fee exclusions or adjustments applied to this certification.",
          "items": {
            "type": "string",
            "enum": [
              "TUITION_ONLY",
              "FEES_INCLUDED",
              "YELLOW_RIBBON_APPLIED"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "housingAllowance": {
      "type": "object",
      "description": "Chapter 4 — Housing Allowance ZIP Code. For Chapter 33 at half-time or more. Conditionally absent for below-half-time or other chapters.",
      "additionalProperties": false,
      "required": [
        "primaryCampusZip",
        "enrollmentModality"
      ],
      "properties": {
        "primaryCampusZip": {
          "type": "string",
          "description": "ZIP code of the primary campus where the student physically attends the majority of classes. Used for DoD BAH MHA calculation. For exclusively online enrollment, enter the student's home ZIP code.",
          "pattern": "^\\d{5}(-\\d{4})?$"
        },
        "enrollmentModality": {
          "type": "string",
          "description": "Enrollment modality indicating degree of in-person vs. online attendance. Affects MHA rate determination.",
          "enum": [
            "ALL_IN_PERSON",
            "MAJORITY_ONLINE",
            "EXCLUSIVELY_ONLINE",
            "HYBRID_LESS_THAN_50_ONLINE"
          ]
        }
      }
    },
    "ojtDetails": {
      "type": "object",
      "description": "Chapter 4 — OJT/Apprenticeship Program Details. Conditionally present when institutionType is OJT_APPRENTICESHIP.",
      "additionalProperties": false,
      "required": [
        "employerName",
        "employerAddress",
        "trainingHoursPerWeek",
        "monthlyTrainingHours",
        "trainingPeriodBeginDate",
        "trainingPeriodEndDate"
      ],
      "properties": {
        "employerName": {
          "type": "string",
          "description": "Name of the employer or training establishment.",
          "minLength": 1,
          "maxLength": 200
        },
        "employerAddress": {
          "$ref": "#/definitions/usAddress",
          "description": "Full address of the employer/training establishment."
        },
        "apprenticeshipRegistrationNumber": {
          "type": "string",
          "description": "Federal or state apprenticeship registration number, if applicable.",
          "maxLength": 50
        },
        "trainingHoursPerWeek": {
          "type": "integer",
          "description": "Number of training hours per week.",
          "minimum": 1,
          "maximum": 168
        },
        "monthlyTrainingHours": {
          "type": "integer",
          "description": "Total monthly training hours for this certification period.",
          "minimum": 1,
          "maximum": 999
        },
        "trainingPhase": {
          "type": "string",
          "description": "Current phase of the apprenticeship training program.",
          "enum": [
            "PROBATIONARY",
            "PHASE_1",
            "PHASE_2",
            "PHASE_3",
            "JOURNEYMAN"
          ]
        },
        "trainingPeriodBeginDate": {
          "$ref": "#/definitions/date",
          "description": "Begin date of the OJT/apprenticeship training period being certified."
        },
        "trainingPeriodEndDate": {
          "$ref": "#/definitions/date",
          "description": "End date of the OJT/apprenticeship training period being certified."
        }
      }
    },
    "amendmentInfo": {
      "type": "object",
      "description": "Chapter 5 — Amendment Details. Conditionally present when certificationTypeSelection is 'amendment'.",
      "additionalProperties": false,
      "required": [
        "originalCertificationId",
        "effectiveDateOfChange",
        "natureOfAmendment"
      ],
      "properties": {
        "originalCertificationId": {
          "type": "string",
          "description": "Confirmation number or VA-ONCE certification ID for the original certification being amended.",
          "minLength": 1,
          "maxLength": 50
        },
        "effectiveDateOfChange": {
          "$ref": "#/definitions/date",
          "description": "The effective date of the enrollment change being reported."
        },
        "natureOfAmendment": {
          "type": "string",
          "description": "The type of change being made by this amendment.",
          "enum": [
            "REDUCTION_IN_HOURS",
            "WITHDRAWAL",
            "PROGRAM_CHANGE",
            "ENROLLMENT_DATE_CORRECTION",
            "OTHER"
          ]
        },
        "lastDateOfAttendance": {
          "$ref": "#/definitions/date",
          "description": "Last date the student attended class. Required when natureOfAmendment is WITHDRAWAL."
        },
        "explanationOfChange": {
          "type": "string",
          "description": "Free-text explanation of the change. Required when natureOfAmendment is OTHER; optional contextual detail for other amendment types.",
          "maxLength": 4000
        },
        "mitigatingCircumstances": {
          "type": "array",
          "description": "Mitigating circumstances claimed when natureOfAmendment is WITHDRAWAL. May reduce or waive overpayment debt under 38 U.S.C. § 3696.",
          "items": {
            "type": "string",
            "enum": [
              "MILITARY_ORDERS",
              "MEDICAL",
              "OTHER_CIRCUMSTANCES"
            ]
          },
          "uniqueItems": true
        },
        "mitigatingCircumstanceExplanation": {
          "type": "string",
          "description": "Explanation of mitigating circumstances including description and supporting documentation to be submitted. Shown when mitigatingCircumstances is non-empty.",
          "maxLength": 4000
        }
      }
    },
    "advancePay": {
      "type": "object",
      "description": "Chapter 5 — Advance Pay Request. Whether the student is requesting advance payment at start of term.",
      "additionalProperties": false,
      "required": [
        "isRequestingAdvancePay"
      ],
      "properties": {
        "isRequestingAdvancePay": {
          "type": "boolean",
          "description": "Whether the student is requesting advance payment for this enrollment period per 38 CFR 21.4136."
        },
        "advancePayAcknowledgments": {
          "type": "array",
          "description": "Required acknowledgments when isRequestingAdvancePay is true. All three items must be present.",
          "items": {
            "type": "string",
            "enum": [
              "STUDENT_AUTHORIZED_ADVANCE_PAY",
              "STUDENT_HAS_DIRECT_DEPOSIT",
              "SUBMITTED_WITHIN_ALLOWABLE_WINDOW"
            ]
          },
          "uniqueItems": true,
          "minItems": 0,
          "maxItems": 3
        }
      }
    },
    "certifierSignature": {
      "type": "object",
      "description": "Chapter 6 — Certifier Certification and Signature. Certification statements, typed digital signature, and submission timestamp.",
      "additionalProperties": false,
      "required": [
        "certificationStatements",
        "typedSignature",
        "signatureTimestamp"
      ],
      "properties": {
        "additionalRemarks": {
          "type": "string",
          "description": "Optional free-text additional comments or remarks for VA that do not fit elsewhere in the form.",
          "maxLength": 4000
        },
        "certificationStatements": {
          "type": "array",
          "description": "Required certification checkboxes. All three statements must be confirmed before submission can proceed.",
          "items": {
            "type": "string",
            "enum": [
              "ENROLLED_AS_DESCRIBED",
              "INFORMATION_IS_ACCURATE",
              "UNDERSTANDS_FALSE_STATEMENT_PENALTIES"
            ]
          },
          "uniqueItems": true,
          "minItems": 3,
          "maxItems": 3
        },
        "typedSignature": {
          "type": "string",
          "description": "SCO's typed full name as digital signature. Must match the authenticated name from Login.gov/ID.me session. Validated at submission time against session identity.",
          "minLength": 1,
          "maxLength": 100
        },
        "signatureTimestamp": {
          "type": "string",
          "description": "ISO 8601 UTC timestamp auto-populated at time of signature/submission. Format: YYYY-MM-DDTHH:mm:ssZ.",
          "format": "date-time"
        }
      }
    },
    "privacyAgreementAccepted": {
      "type": "boolean",
      "description": "Platform-required privacy agreement acceptance. Must be true for form submission to proceed.",
      "enum": [
        true
      ]
    },
    "duplicateCheckResult": {
      "type": "object",
      "description": "Result of the pre-submission duplicate check against VA-ONCE records. Read-only. Not user input.",
      "additionalProperties": false,
      "properties": {
        "duplicateCheckPerformed": {
          "type": "boolean"
        },
        "potentialDuplicateFound": {
          "type": "boolean"
        },
        "duplicateCheckTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "scoProceedDespiteDuplicate": {
          "type": "boolean",
          "description": "True when the SCO has acknowledged the duplicate warning and explicitly chosen to proceed with submission."
        }
      }
    },
    "submissionMetadata": {
      "type": "object",
      "description": "Submission routing and processing metadata. Populated at submission time by the backend. Not user input.",
      "additionalProperties": false,
      "properties": {
        "confirmationNumber": {
          "type": "string",
          "description": "VA-assigned confirmation number for this submission.",
          "maxLength": 50
        },
        "submissionTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "routedToRpo": {
          "type": "string",
          "description": "RPO this submission was routed to based on institution location.",
          "enum": [
            "BUFFALO",
            "MUSKOGEE",
            "ST_LOUIS"
          ]
        },
        "formVersion": {
          "type": "string",
          "description": "Schema version of the form at time of submission.",
          "maxLength": 20
        }
      }
    }
  }
}